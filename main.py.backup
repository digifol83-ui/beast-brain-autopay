"""brain-api — Cloud Run agent service.

Endpoints:
  GET  /                  chat UI (HTML)
  GET  /health            JSON health
  GET  /agent-kit         browser-readable backend agent resource kit
  GET  /api/agent-kit     JSON backend agent resource kit
  GET  /beastbrain        browser-readable BeastBrain build map
  GET  /api/beastbrain/overview JSON BeastBrain build map data
  POST /chat              {message, session_id?, reasoner?} -> {reply, session_id, trace, reasoner}
  GET  /sessions          list recent session ids
  GET  /sessions/{id}     get full transcript
  POST /run-research-loop {topic, save_digest?} -> autonomous research run
"""
