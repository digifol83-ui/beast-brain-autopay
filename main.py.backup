    amount_usd: float | None = None
    crypto: str | None = None
    crypto_currency: str | None = None
    network: str | None = None
    wallet_address: str | None = None
    email: str | None = None
    customer_name: str | None = None
    customer_address_line1: str | None = None
    customer_address_line2: str | None = None
    customer_city: str | None = None
    customer_state: str | None = None
    customer_zip: str | None = None
    customer_country: str | None = None


def _resolve_gateway_payment_amounts(body: GatewayPaymentIn) -> dict[str, float | str]:
    source_currency = (body.fiat_currency or "").strip().upper() or "AED"
    if body.amount_usd is not None:
        source_currency = "USD"
        source_amount = round(float(body.amount_usd), 2)
        amount_aed = round(source_amount * aed_per_usd(), 2)
    elif body.fiat_amount is not None:
        if source_currency not in {"AED", "USD", "EUR", "GBP"}:
            raise HTTPException(400, "fiat_currency must be AED, USD, EUR, or GBP for hosted card onramps")
        source_amount = round(float(body.fiat_amount), 2)
        if source_currency == "USD":
            amount_aed = round(source_amount * aed_per_usd(), 2)
        elif source_currency == "EUR":
            amount_aed = round(source_amount * 4.0, 2)  # ~1 EUR = 4 AED
        elif source_currency == "GBP":
            amount_aed = round(source_amount * 4.65, 2)  # ~1 GBP = 4.65 AED
        else:
            amount_aed = source_amount
    elif body.amount_aed is not None:
        source_currency = "AED"
        amount_aed = round(float(body.amount_aed), 2)
        source_amount = amount_aed
    else:
        raise HTTPException(400, "amount_aed or fiat_amount is required")

    amount_usd = source_amount if source_currency == "USD" else round(amount_aed / aed_per_usd(), 2)
    return {
        "amount_aed": amount_aed,
        "amount_usd": round(float(amount_usd), 2),
        "source_fiat_amount": source_amount,
        "source_fiat_currency": source_currency,
    }


def _gateway_payment_uses_fixed_solana_wallet(body: GatewayPaymentIn) -> bool:
    crypto_id = (body.crypto or "").strip().upper()
    return body.gateway_id in {"moonpay", "onramper"} and crypto_id == "SOL"


