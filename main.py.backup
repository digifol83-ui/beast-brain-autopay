@app.get("/api/card-to-crypto/copilot")
def card_to_crypto_copilot():
    """Return the card-to-crypto progress copilot with stage agents and telemetry."""
    gateway_data = get_real_card_payment_gateways()
    active_gateways = [g["id"] for g in gateway_data["gateways"] if g.get("real_trade_active")]
    hundred_percent = _card_to_crypto_hundred_percent_readiness(gateway_data, active_gateways)

    stage_agents = [
        {"id": "route_status_agent", "special_skill": "route_status_checker", "facility_urls": ["/api/card-to-crypto/status"], "next_action": "Check route status", "hard_stop": "No raw card, CVV, OTP, 3DS, or bank-push data enters BeastBrain.", "can_complete_automatically": True, "status": "ready"},
        {"id": "gateway_selection_agent", "special_skill": "gateway_selector", "facility_urls": ["/api/payment-gateways/real-card", "/api/card-to-crypto/checkout"], "next_action": "Select gateway and create checkout", "hard_stop": "No raw card, CVV, OTP, 3DS, or bank-push data enters BeastBrain.", "can_complete_automatically": True, "status": "ready"},
        {"id": "p2p_backup_agent", "special_skill": "manual_p2p_route_coordinator", "facility_urls": ["/api/card-to-crypto/p2p-routes", "/api/card-to-crypto/proofs"], "next_action": "withdraw to BeastBrain wallet and record withdrawal transaction hash", "hard_stop": "No raw card, CVV, OTP, 3DS, or bank-push data enters BeastBrain.", "can_complete_automatically": False, "status": "ready"},
        {"id": "sumsub_metadata_agent", "special_skill": "sumsub_metadata_handler", "facility_urls": ["/api/kyc/users", "/api/card-to-crypto/checkout"], "next_action": "Store KYC metadata only, no documents", "hard_stop": "No raw card, CVV, OTP, 3DS, or bank-push data enters BeastBrain.", "can_complete_automatically": True, "status": "ready"},
        {"id": "checkout_handoff_agent", "special_skill": "hosted_checkout_url_builder", "facility_urls": ["/api/card-to-crypto/checkout"], "next_action": "Create hosted checkout URL", "hard_stop": "No raw card, CVV, OTP, 3DS, or bank-push data enters BeastBrain.", "can_complete_automatically": True, "status": "ready"},
        {"id": "provider_challenge_agent", "special_skill": "provider_challenge_detector", "facility_urls": ["/api/card-to-crypto/status"], "next_action": "Detect provider or issuer challenge", "hard_stop": "No raw card, CVV, OTP, 3DS, or bank-push data enters BeastBrain.", "can_complete_automatically": False, "status": "pending_provider_or_issuer"},
        {"id": "settlement_proof_agent", "special_skill": "settlement_proof_collector", "facility_urls": ["/api/card-to-crypto/proofs", "/api/webhooks/card-to-crypto/{provider}"], "next_action": "Collect settlement proof", "hard_stop": "No raw card, CVV, OTP, 3DS, or bank-push data enters BeastBrain.", "can_complete_automatically": False, "status": "blocked_until_provider_webhook_and_wallet_receipt"},
    ]

    p2p_routes = _build_p2p_routes_response()
    remaining_percent = 100 - hundred_percent["current_readiness_percent"]
    remaining_tasks = [
        {"id": "provider_order_status_proof", "difficulty": "easiest", "facility_url": "/api/webhooks/card-to-crypto/{provider}", "verify_urls": ["/api/card-to-crypto/webhooks/recent"], "can_prepare_now": True, "can_complete_without_real_event": False},
        {"id": "real_card_authorization", "difficulty": "medium", "facility_url": "/api/card-to-crypto/checkout", "verify_urls": ["/api/card-to-crypto/status"], "can_prepare_now": True, "can_complete_without_real_event": False},
        {"id": "wallet_receipt_tx_proof", "difficulty": "hardest", "facility_url": "/api/card-to-crypto/proofs", "verify_urls": ["/api/card-to-crypto/proofs"], "can_prepare_now": True, "can_complete_without_real_event": False, "proof_template": {"tx_hash": "<required_chain_transaction_hash>"}},
    ]

    return {
        "copilot": {"id": "card_to_crypto_progress_copilot"},
        "browser_computer": {"status": "browser_computer_ready", "readiness_percent": 100, "is_ready": True, "banxa_verified": True, "not_settlement_proof": True},
        "right_side_url": "https://beastbrain.sichermayor.online/card-to-crypto",
        "checkout_route": "/api/card-to-crypto/checkout",
        "status_route": "/api/card-to-crypto/status",
        "p2p_route": "/api/card-to-crypto/p2p-routes",
        "progress": {
            "current_readiness_percent": hundred_percent["current_readiness_percent"],
            "settlement_readiness_percent": hundred_percent["current_readiness_percent"],
            "browser_computer_readiness_percent": 100,
            "is_browser_computer_ready": True,
            "remaining_readiness_percent": remaining_percent,
            "current_blockers": hundred_percent.get("blocking_deformities", []),
        },
        "safety": {"raw_card_data_stored": False, "merchant_otp_supported": False, "merchant_side_3ds_supported": False},
        "stage_agents": stage_agents,
        "p2p_backup": {
            "status": "manual_p2p_backup_active",
            "route_type": "manual_p2p_to_wallet",
            "record_proof_url": "/api/card-to-crypto/proofs",
            "direct_card_entry": False,
            "wallet_receipt_required": True,
            "recommended_token_network": p2p_routes["recommended_token_network"],
            "alternate_token_networks": p2p_routes["alternate_token_networks"],
            "routes": p2p_routes["routes"],
            "completion_rule": "P2P is complete only after exchange release, withdrawal, and verified BeastBrain wallet tx hash.",
        },
        "remaining_38_percent": {
            "remaining_percent": remaining_percent,
            "created": True,
            "sorted_by": "easiest_to_hardest",
            "completion_rule": "Do not mark any task complete without real provider or wallet evidence.",
            "sorted_tasks": remaining_tasks,
