    }


@app.api_route("/api/alchemy-pay/callback", methods=["GET", "POST"])
async def alchemy_pay_callback(request: Request):
    """Acknowledge Alchemy Pay callbackUrl/webhook delivery without trusting it."""
    content_type = request.headers.get("content-type", "")
    payload_keys: list[str] = []
    payload_kind = "query" if request.method == "GET" else "body"
    if request.method == "GET":
        payload_keys = sorted(request.query_params.keys())
    elif "application/json" in content_type.lower():
        try:
            payload = await request.json()
        except json.JSONDecodeError:
            payload = {}
            payload_kind = "invalid_json"
        if isinstance(payload, dict):
            payload_keys = sorted(str(key) for key in payload.keys())
    else:
        raw_body = await request.body()
        payload_kind = "raw_body" if raw_body else "empty_body"

    return {
        "success": True,
        "provider": "alchemy_pay",
        "status": "callback_received",
        "method": request.method,
        "payload_kind": payload_kind,
        "payload_keys": payload_keys,
        "timestamp_header_present": bool(request.headers.get("timestamp")),
        "signature_header_present": bool(
            request.headers.get("sign")
            or request.headers.get("signature")
            or request.headers.get("x-signature")
        ),
        "raw_payload_stored": False,
        "crediting_boundary": (
            "Receipt is acknowledged only. Order crediting must use Alchemy Pay "
            "signature verification and/or Order Query API after provider approval."
        ),
        "recommended_callback_url": "https://beastbrain.sichermayor.online/api/alchemy-pay/callback",
    }


@app.post("/api/gateway-payment")
def gateway_payment(body: GatewayPaymentIn):
    """Create a hosted fiat-to-crypto card checkout.

    Transak and Stripe are excluded. BeastBrain returns a provider-hosted URL and
    never accepts raw card numbers, CVV, or expiry data.
    """
    import uuid, time

    amount_info = _resolve_gateway_payment_amounts(body)
    amount_aed = float(amount_info["amount_aed"])
    if amount_aed <= 0:
        raise HTTPException(400, "amount must be positive")
    if amount_aed < 25:
        raise HTTPException(400, "amount must be at least 25 AED for hosted card onramps")

    # Find gateway config
    all_gateways = get_real_card_onramps()
    gateway = next((g for g in all_gateways if g["id"] == body.gateway_id), None)
    if not gateway:
        raise HTTPException(404, f"real card onramp not found or disabled: {body.gateway_id}")
    readiness = _real_card_gateway_readiness(body.gateway_id)
    if not readiness.get("real_trade_active"):
        raise HTTPException(400, f"gateway {body.gateway_id} is not active for trade on this deployment")

    payment_id = f"bb-{uuid.uuid4()}"

    # KYC tier logic
    if amount_aed < KYC_TIERS["none"]:
        kyc_tier = "none"
    elif amount_aed < KYC_TIERS["email"]:
        kyc_tier = "email"
    else:
        kyc_tier = "full_sumsub"

    # Check if amount exceeds no-KYC limit for this gateway
    gateway_limit = NO_KYC_GATEWAY_LIMITS.get(body.gateway_id, 0)
    exceeds_limit = amount_aed > gateway_limit
    permanent_wallet = None
    effective_wallet_address = body.wallet_address
    effective_network = body.network
    permanent_wallet_used = False
    backend_wallet_locked = False
    wallet_source = "request_wallet_address" if effective_wallet_address else None
    if _gateway_payment_uses_fixed_solana_wallet(body):
        permanent_wallet = resolve_permanent_wallet("SOL", "solana")
        effective_wallet_address = permanent_wallet["wallet_address"]
        effective_network = permanent_wallet["network"]
        permanent_wallet_used = bool(effective_wallet_address)
        backend_wallet_locked = True
        wallet_source = "backend_permanent_solana_wallet" if permanent_wallet_used else None
    if not effective_wallet_address:
        permanent_wallet = resolve_permanent_wallet(body.crypto, body.network)
        effective_wallet_address = permanent_wallet["wallet_address"]
        effective_network = permanent_wallet["network"]
        permanent_wallet_used = bool(effective_wallet_address)
        wallet_source = permanent_wallet["source"] if permanent_wallet_used else None

    try:
        checkout = build_hosted_card_checkout(
            gateway_id=body.gateway_id,
            amount_aed=amount_aed,
            crypto=body.crypto,
            wallet_address=effective_wallet_address,
            network=effective_network,
            payment_id=payment_id,
            lock_card_for_auto_payments=body.lock_card_for_auto_payments,
            autopay_cadence=body.autopay_cadence,
            autopay_limit_aed=body.autopay_limit_aed,
            customer_email=body.email,
            payment_method=body.payment_method,
            fiat_currency=amount_info.get("source_fiat_currency", "AED"),
        )
    except ValueError as e:
        raise HTTPException(400, str(e))

    response = {
        "payment_id": payment_id,
        "gateway": {
            "id": body.gateway_id,
            "name": gateway.get("name"),
            "type": gateway.get("type"),
            "url": gateway.get("url"),
            "fee": gateway.get("fee"),
            "kyc_provider": gateway.get("kyc_provider"),
            "kyc_status_storage": gateway.get("kyc_status_storage"),
            "kyc_document_storage": gateway.get("kyc_document_storage"),
            "raw_card_data_stored": gateway.get("raw_card_data_stored", False),
            "merchant_otp_supported": gateway.get("merchant_otp_supported", False),
            "merchant_side_3ds_supported": gateway.get("merchant_side_3ds_supported", False),
        },
        "amount_aed": amount_aed,
        "amount_usd": amount_info["amount_usd"],
        "source_fiat_amount": amount_info["source_fiat_amount"],
        "source_fiat_currency": amount_info["source_fiat_currency"],
        "crypto": body.crypto or "N/A",
        "wallet": effective_wallet_address or "provider_checkout",
        "network": checkout["wallet_network"] or "provider_checkout",
        "wallet_source": wallet_source,
        "backend_wallet_locked": backend_wallet_locked,
        "wallet_input_required_by_beastbrain": False,
        "permanent_wallet_used": permanent_wallet_used,
        "permanent_wallet_source": permanent_wallet["source"] if permanent_wallet_used and permanent_wallet else None,
        "permanent_wallet_configured_networks": configured_permanent_wallet_networks(),
        "status": "checkout_url_created",
        "kyc_tier_required": kyc_tier,
        "no_kyc_limit_aed": gateway_limit,
        "exceeds_no_kyc_limit": exceeds_limit,
        "settlement_time": gateway.get("settlement", "varies"),
        "merchant_otp_required": False,
        "merchant_side_3ds_otp": "removed",
        "external_challenge_owner": "hosted_provider_or_card_issuer",
        "raw_card_data_handled_by": checkout.get("card_data_handled_by", "hosted_onramp_provider"),
        "payment_mode": body.payment_mode or ("auto_credit" if body.lock_card_for_auto_payments else "spot_pay"),
        "card_detail_source": body.card_detail_source or "new_hosted_checkout",
        "single_sdk": "beastbrain_hosted_card_sdk",
        "link_handoff_url": "https://app.link.com/login" if body.card_detail_source == "link_app_handoff" else None,
        "beastbrain_card_storage": "none",
        "raw_card_data_stored": checkout.get("raw_card_data_stored", False),
        "merchant_otp_supported": checkout.get("merchant_otp_supported", False),
        "merchant_side_3ds_supported": checkout.get("merchant_side_3ds_supported", False),
        "card_last4": body.card_last4,
        "card_brand": body.card_brand,
        "timestamp": int(time.time()),
        "checkout_url": checkout["checkout_url"],
        "redirect_url": checkout["checkout_url"],
        "payment_method_requested": body.payment_method or checkout.get("payment_method", "creditcard"),
        "excluded_payment_methods": checkout.get("excluded_payment_methods", []),
        "customer_email": body.email or checkout.get("customer_email"),
        "requires_redirect": True,
        "checkout_provider": checkout["checkout_provider"],
        "allowed_onramps": checkout["allowed_onramps"],
        "onramper_fallback_reason": checkout.get("onramper_fallback_reason"),
        "wallet_prefilled": checkout["wallet_prefilled"],
        "wallet_prefill_ready": checkout["wallet_prefilled"],
        "wallet_prefill_requires": checkout["wallet_prefill_requires"],
        "api_key_configured": checkout["api_key_configured"],
        "api_key_source": checkout.get("api_key_source"),
        "api_key_status": checkout.get("api_key_status"),
        "ignored_api_key_source": checkout.get("ignored_api_key_source"),
        "onramper_account_mode": checkout.get("onramper_account_mode"),
        "link_mode": checkout.get("link_mode"),
        "provider_account_mode": checkout.get("provider_account_mode"),
        "alchemy_pay_env": checkout.get("alchemy_pay_env"),
        "guardarian_env": checkout.get("guardarian_env"),
        "nexapay_env": checkout.get("nexapay_env"),
        "wert_env": checkout.get("wert_env"),
        "worldpay_api": checkout.get("worldpay_api"),
        "worldpay_access_base_url": checkout.get("worldpay_access_base_url"),
        "worldpay_token_namespace": checkout.get("worldpay_token_namespace"),
        "worldpay_go_live_checklist": checkout.get("worldpay_go_live_checklist"),
        "provider_currency": checkout.get("provider_currency"),
        "provider_amount": checkout.get("provider_amount"),
        "provider_crypto": checkout.get("provider_crypto"),
        "provider_crypto_id": checkout.get("provider_crypto_id"),
        "provider_network": checkout.get("provider_network"),
        "target_crypto": checkout.get("target_crypto"),
        "two_step_conversion_required": checkout.get("two_step_conversion_required", False),
        "conversion_plan": checkout.get("conversion_plan"),
        "widget_session_expires_in_seconds": checkout.get("widget_session_expires_in_seconds"),
        "fee_range": checkout.get("fee_range"),
        "kyc_policy_claim": checkout.get("kyc_policy_claim"),
        "risk_note": checkout.get("risk_note"),
        "signing_secret_configured": checkout.get("signing_secret_configured", False),
        "signing_secret_source": checkout.get("signing_secret_source"),
        "excluded_providers": ["transak", "stripe"],
        "stripe_role": "not_used_for_hosted_crypto_checkout",
        "stripe_wallet_used": False,
        "crypto_conversion_owner": "hosted_crypto_payment_gateways",
    }
    if body.lock_card_for_auto_payments:
        response["auto_payment"] = checkout["auto_payment"]

    if body.crypto:
        PRICES = {"USDT": 3.67, "USDC": 3.67, "ETH": 14500, "BTC": 250000, "SOL": 650}
        crypto_amount = amount_aed / PRICES.get(body.crypto, 3.67)
        response["crypto_amount"] = round(crypto_amount, 8)
    if body.lock_card_for_auto_payments:
        response["message"] = (
            f"Open hosted checkout via {gateway['name']} to authorize this payment and lock the card "
            "for future auto payments. Card tokenization and consent are handled by the hosted provider."
        )
    else:
        response["message"] = (
            f"Open hosted checkout via {gateway['name']}. Card payment and KYC are handled by the provider."
        )

    assist = _record_payment_ops_assist_safe(
        source="gateway_payment_checkout_created",
        event_type="hosted_card_to_crypto_checkout",
        provider=body.gateway_id,
        payment_id=payment_id,
        amount_aed=amount_aed,
        metadata={
            "crypto": body.crypto,
            "network": effective_network,
            "permanent_wallet_used": permanent_wallet_used,
            "payment_mode": body.payment_mode or ("auto_credit" if body.lock_card_for_auto_payments else "spot_pay"),
            "card_detail_source": body.card_detail_source or "new_hosted_checkout",
            "lock_card_for_auto_payments": body.lock_card_for_auto_payments,
            "stripe_role": "not_used_for_hosted_crypto_checkout",
        },
    )
    response["payment_ops_assist"] = assist
    return response


@app.post("/api/card-to-crypto/checkout")
def card_to_crypto_checkout(body: CardToCryptoCheckoutIn):
    crypto = (body.crypto or body.crypto_currency or "USDT").strip().upper()
    checkout = gateway_payment(GatewayPaymentIn(
        gateway_id=body.gateway_id or "moonpay",
        amount_aed=body.amount_aed,
        fiat_amount=body.fiat_amount,
        fiat_currency=body.fiat_currency,
        amount_usd=body.amount_usd,
        crypto=crypto,
        network=body.network,
        wallet_address=body.wallet_address,
        email=body.email,
        payment_mode="spot_pay",
        card_detail_source="new_hosted_checkout",
        lock_card_for_auto_payments=False,
    ))
    # Attach customer details for USA client support
    customer = {}
    if body.customer_name: customer["name"] = body.customer_name
    if body.customer_address_line1: customer["address_line1"] = body.customer_address_line1
    if body.customer_address_line2: customer["address_line2"] = body.customer_address_line2
    if body.customer_city: customer["city"] = body.customer_city
    if body.customer_state: customer["state"] = body.customer_state
    if body.customer_zip: customer["zip"] = body.customer_zip
    if body.customer_country: customer["country"] = body.customer_country
    if customer:
        checkout["customer"] = customer

    checkout.update({
        "card_to_crypto_route": "/api/card-to-crypto/checkout",
        "engine_route": "/api/gateway-payment",
        "page_url": "/card-to-crypto",
        "direct_card_entry": False,
        "raw_card_data_stored": False,
        "merchant_otp_supported": False,
        "merchant_side_3ds_supported": False,
        "tokenization_supported": False,
        "provider_challenge_owner": "hosted_provider_or_card_issuer",
        "card_entry": "hosted_provider_checkout",
        "fiat_currency_supported": "AED, USD, EUR, GBP",
        "boundary": {
            "card_details": "Card entry stays inside the hosted provider checkout.",
            "otp": "not collected by BeastBrain",
            "issuer_challenge": "provider_or_issuer_owned",
            "silent_deduction": "blocked_without_provider_mandate",
        },
    })
    return checkout


