class IdeVmEventIn(BaseModel):
    event_type: str = Field(default="blocker_recorded", max_length=80)
    target_url: str | None = Field(default=None, max_length=500)
    note: str | None = Field(default=None, max_length=500)
    protocol_gate: str = Field(default="safe", max_length=40)


class IdeVmHumanTouchIn(BaseModel):
