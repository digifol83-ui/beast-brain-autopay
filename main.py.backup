class GatewayActivationRequestIn(BaseModel):
    gateway_name: str
    gateway_type: str = "card-to-crypto"
    provider_url: str = ""
    contact_email: str = ""
    target_crypto: str = "USDT"
    notes: str = ""


def _gateway_request_public(item: dict[str, Any]) -> dict[str, Any]:
    allowed = {
        "request_id",
        "gateway_name",
        "gateway_type",
        "provider_url",
        "contact_email",
        "target_crypto",
        "notes",
        "status",
        "status_color",
        "reason",
        "created_at",
    }
    return {key: item.get(key) for key in allowed if key in item}


@app.get("/api/payment-gateway-requests")
def list_gateway_requests():
    state = project_store.load_state()
    return {
        "requests": [
            _gateway_request_public(item)
            for item in state.get("gateway_requests", [])
        ]
    }


@app.post("/api/payment-gateway-requests")
def create_gateway_request(body: GatewayActivationRequestIn):
    name = body.gateway_name.strip()
    if not name:
        raise HTTPException(400, "gateway name is required")

    notes = body.notes.strip()
    secret_terms = ("api key", "apikey", "secret", "password", "otp", "token")
    if any(term in notes.lower() for term in secret_terms):
        raise HTTPException(400, "do not paste API keys, secrets, tokens, passwords, or OTPs here")

    state = project_store.load_state()
    item = {
        "request_id": project_store.new_id("gwreq"),
        "gateway_name": name[:80],
        "gateway_type": (body.gateway_type or "card-to-crypto")[:40],
        "provider_url": body.provider_url.strip()[:240],
        "contact_email": body.contact_email.strip()[:120],
        "target_crypto": (body.target_crypto or "USDT").strip().upper()[:12],
        "notes": notes[:500],
        "status": "requested",
        "status_color": "red",
        "reason": "Saved as a request. It is not active for real card money until provider approval and production credentials are mounted.",
        "created_at": project_store.now_iso(),
    }
    state.setdefault("gateway_requests", []).append(item)
    project_store.save_state(state)
    return _gateway_request_public(item)


@app.delete("/api/payment-gateway-requests/{request_id}")
def delete_gateway_request(request_id: str):
    state = project_store.load_state()
    requests = state.get("gateway_requests", [])
    kept = [item for item in requests if item.get("request_id") != request_id]
    if len(kept) == len(requests):
        raise HTTPException(404, "gateway request not found")
    state["gateway_requests"] = kept
    project_store.save_state(state)
    return {"deleted": request_id}


class GatewayPaymentIn(BaseModel):
    gateway_id: str  # "moonpay", "simplex", "telegram_stars", etc.
    amount_aed: float | None = None
    fiat_amount: float | None = None
    fiat_currency: str = "AED"
    amount_usd: float | None = None
    crypto: str | None = None  # Not needed for Telegram Stars
    network: str | None = None
    wallet_address: str | None = None  # 0x... for crypto, @username for Telegram
    payment_mode: str | None = None
