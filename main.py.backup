def _env_flag(name: str) -> bool:
    return os.getenv(name, "").strip().lower() in {"1", "true", "yes", "live", "verified"}


def _auto_enabled(env_name: str) -> bool:
    val = os.getenv(env_name, "").strip().lower()
    if val in {"1", "true", "yes", "on"}:
        return True
    if val in {"0", "false", "off", "no"}:
        return False
    return False


def _env_or_proof_flag(name: str, proof_summary_key: str, proof_summary: dict[str, bool]) -> bool:
    """Check an env flag first, then fall back to stored proof data."""
    if _env_flag(name):
        return True
    return proof_summary.get(proof_summary_key, False)


def _card_to_crypto_merchant_friction_reduction_policy() -> dict[str, Any]:
    return {
        "status": "reduce_customer_burden_lawfully",
        "summary": (
            "BeastBrain can ask the hosted provider/acquirer for the lowest-friction lawful checkout, "
            "but it cannot bypass or take over CAPTCHA, OTP, MFA, issuer 3DS, KYC, or customer consent."
        ),
        "can_request_provider_settings": [
            {
                "id": "3ds2_frictionless",
                "label": "3DS2 frictionless / risk-based authentication",
                "detail": "Send richer checkout risk data through the hosted provider so the issuer may authenticate low-risk payments without an extra customer step.",
            },
            {
                "id": "sca_exemptions_where_supported",
                "label": "SCA exemptions where provider and acquirer support them",
                "detail": "Ask for low-value, transaction-risk-analysis, secure-corporate, trusted-beneficiary, or comparable exemptions where the provider can legally request them.",
            },
            {
                "id": "data_only_or_network_risk_data",
                "label": "Data-only or network risk data",
                "detail": "Ask providers that support card-network risk-data products to use them for eligible low-risk payments.",
            },
            {
                "id": "wallet_payment_buttons",
                "label": "Wallet payment buttons",
                "detail": "Offer Apple Pay, Google Pay, or provider wallet buttons when the onramp supports them, because wallet authentication can reduce card-entry friction.",
            },
            {
                "id": "provider_tokenized_card_on_file",
                "label": "Provider tokenized card-on-file",
                "detail": "Use provider-hosted card saving only after the customer authenticates and consents in the first checkout.",
            },
            {
                "id": "mit_after_initial_consent",
                "label": "Merchant-initiated transactions after first consent",
                "detail": "Only request MIT/off-session capability after an initial authenticated setup, signed customer mandate, provider approval, and webhook/order-status proof.",
            },
        ],
        "hard_stop_controls": [
            "CAPTCHA remains a provider/operator human-gate and cannot be bypassed by BeastBrain.",
            "OTP and MFA remain account-owner or customer challenges and cannot be collected or replayed by BeastBrain.",
            "Issuer 3DS challenge remains provider/issuer-owned; BeastBrain can request frictionless handling but cannot force approval.",
            "KYC/KYB documents, legal terms, and subscriptions require the legitimate account owner/provider portal.",
            "Raw card number, CVV, expiry, OTP, and 3DS data must not enter BeastBrain.",
        ],
        "provider_ask": (
            "Please enable the lowest-friction compliant card-to-crypto checkout for beastbrain.sichermayor.online, "
            "including 3DS2 frictionless/risk-based authentication, applicable exemption requests, wallet payment options, "
            "and provider-tokenized card-on-file/MIT only after customer consent and first authentication."
        ),
        "current_result": "Not active yet: provider approval, production credentials, webhook/order proof, real card authorization, and wallet receipt proof are still required.",
        "not_legal_advice": True,
    }


def _card_to_crypto_hundred_percent_readiness(gateway_data: dict[str, Any], active_gateways: list[str]) -> dict[str, Any]:
    gateway_by_id = {gateway["id"]: gateway for gateway in gateway_data.get("gateways", [])}
    partner_provider_ids = {"alchemy_pay", "guardarian", "nexapay", "wert", "banxa", "ramp_network"}
    live_partner_providers = [
        provider_id
        for provider_id in partner_provider_ids
        if gateway_by_id.get(provider_id, {}).get("real_trade_active")
    ]
    onramper_key = onramper_public_api_key_status()
    production_credentials_ready = bool(onramper_key["live_key_mounted"] or live_partner_providers)
    provider_approval_verified = _env_flag("BEASTBRAIN_CARD_TO_CRYPTO_PROVIDER_APPROVED")

    # Build recorded_proof_summary early so gates can check stored proof data
    _c2c_state_readiness = project_store.load_state()
    _events_readiness = _c2c_state_readiness.get("card_to_crypto_webhook_events", [])
    _readiness_proof_summary_local = _c2c_webhooks.event_summary() if hasattr(_c2c_webhooks, 'event_summary') else {}
    webhook_verified = _env_or_proof_flag("BEASTBRAIN_CARD_TO_CRYPTO_WEBHOOK_VERIFIED", "webhook_verified", _readiness_proof_summary_local)
    live_payment_verified = _env_or_proof_flag("BEASTBRAIN_CARD_TO_CRYPTO_LIVE_PAYMENT_VERIFIED", "live_payment_verified", _readiness_proof_summary_local)
    wallet_receipt_verified = _env_or_proof_flag("BEASTBRAIN_CARD_TO_CRYPTO_WALLET_RECEIPT_VERIFIED", "wallet_receipt_verified", _readiness_proof_summary_local)
    configured_wallets = configured_permanent_wallet_networks()
    wallet_configured = bool(configured_wallets)

    state = project_store.load_state()
    requested_gateways = [
        {
            "name": request.get("gateway_name"),
            "type": request.get("gateway_type"),
            "status": request.get("status"),
            "status_color": request.get("status_color"),
        }
        for request in state.get("gateway_requests", [])
        if request.get("status_color") == "red"
    ]

    criteria = [
        {
            "id": "hosted_checkout_route_live",
            "label": "Public page and hosted checkout API are live",
            "met": bool(active_gateways),
            "evidence": "/card-to-crypto, /api/card-to-crypto/status, and /api/card-to-crypto/checkout are wired.",
        },
        {
            "id": "safe_card_boundary",
            "label": "No raw card, CVV, OTP, or merchant-side 3DS in BeastBrain",
            "met": True,
            "evidence": "Card entry and issuer challenges stay inside hosted provider checkout.",
        },
        {
            "id": "production_provider_credentials",
            "label": "Production provider credentials are mounted and not test-like",
            "met": production_credentials_ready,
            "evidence": (
                f"Onramper key status is {onramper_key['status']}."
                if not live_partner_providers
                else f"Live partner providers: {', '.join(sorted(live_partner_providers))}."
            ),
            "blocker": None if production_credentials_ready else "Live Onramper key or approved partner credentials are still missing.",
        },
        {
            "id": "provider_account_domain_approval",
            "label": "Provider account, KYB, domain, and go-live approval are confirmed",
            "met": provider_approval_verified,
            "evidence": "Requires BEASTBRAIN_CARD_TO_CRYPTO_PROVIDER_APPROVED=verified after provider confirmation.",
            "blocker": None if provider_approval_verified else "Provider/KYB/domain approval is not verified by BeastBrain yet.",
        },
        {
            "id": "wallet_network_settlement_path",
            "label": "Destination wallet and network path are fixed for settlement",
            "met": wallet_configured and production_credentials_ready,
            "partial": wallet_configured and not production_credentials_ready,
            "evidence": f"Configured wallet networks: {', '.join(configured_wallets) if configured_wallets else 'none'}.",
            "blocker": None if wallet_configured and production_credentials_ready else "Wallet exists, but signed provider wallet prefill still needs live provider credentials.",
        },
        {
            "id": "webhook_or_order_status_verified",
            "label": "Provider webhook or order-status verification is live",
            "met": webhook_verified,
            "evidence": "Requires BEASTBRAIN_CARD_TO_CRYPTO_WEBHOOK_VERIFIED=verified after signed callback/order checks pass.",
            "blocker": None if webhook_verified else "No verified provider callback/order-status proof is recorded.",
        },
        {
            "id": "live_payment_authorized",
            "label": "A real customer card payment was authorized by the hosted provider",
            "met": live_payment_verified,
            "evidence": "Requires BEASTBRAIN_CARD_TO_CRYPTO_LIVE_PAYMENT_VERIFIED=verified after a real provider-side payment succeeds.",
            "blocker": None if live_payment_verified else "Checkout URL creation is not proof of a completed card charge.",
        },
        {
            "id": "crypto_received_in_beastbrain_wallet",
            "label": "Crypto receipt reached the BeastBrain wallet on the correct network",
            "met": wallet_receipt_verified,
            "evidence": "Requires BEASTBRAIN_CARD_TO_CRYPTO_WALLET_RECEIPT_VERIFIED=verified after chain/wallet receipt is confirmed.",
            "blocker": None if wallet_receipt_verified else "No wallet/chain receipt proof is recorded for a fiat-card transaction.",
        },
    ]
    met_weight = 0.0
    for criterion in criteria:
        if criterion.get("met"):
            criterion["status"] = "met"
            met_weight += 1
        elif criterion.get("partial"):
            criterion["status"] = "partial"
            met_weight += 0.5
        else:
            criterion["status"] = "blocked"

    blockers = [
        criterion["blocker"]
        for criterion in criteria
        if criterion.get("blocker")
    ]
    if requested_gateways:
        blockers.append("Gateway requests are still red/requested until providers approve onboarding and issue production access.")

    is_100_percent_live = all(criterion["met"] for criterion in criteria)
    if not is_100_percent_live:
        blockers.append("CryptAPI / BlockBee is crypto-in only; it does not solve fiat/card-to-crypto.")    
    # Build recorded_proof_summary from webhook events (reuses already-loaded data)
    _events_readiness = _c2c_state_readiness.get("card_to_crypto_webhook_events", [])
    recorded_proof_summary = {
        "total_events": len(_events_readiness),
        "verified_events": len([e for e in _events_readiness if e.get("verified")]),
        "completed_events": len([e for e in _events_readiness if e.get("status") in ("completed", "settled")]),
        "events_with_tx_hash": len([e for e in _events_readiness if e.get("tx_hash")]),
        "webhook_verified": _readiness_proof_summary_local.get("webhook_verified", False),
        "live_payment_verified": _readiness_proof_summary_local.get("live_payment_verified", False),
        "wallet_receipt_verified": _readiness_proof_summary_local.get("wallet_receipt_verified", False),
    }
    automation_limits = [
        {
            "id": "provider_merchant_approval",
            "owner": "provider",
            "limit": "BeastBrain cannot approve its own merchant account, KYB, domain allowlist, or production access.",
            "unlock": "Provider sends approval and production onboarding confirmation through an official channel.",
        },
        {
            "id": "legal_terms_or_subscription",
            "owner": "operator_and_provider",
            "limit": "Automation cannot accept legal terms, buy a provider subscription, sign agreements, or approve commercial fees.",
            "unlock": "The operator accepts terms or subscriptions directly in the legitimate provider dashboard.",
        },
        {
            "id": "private_kyb_document_upload",
            "owner": "operator",
            "limit": "Automation cannot upload private identity, company, bank, or ownership documents unless the operator explicitly performs the provider upload.",
            "unlock": "Operator uploads documents through the official provider secure portal.",
        },
        {
            "id": "captcha_otp_mfa",
            "owner": "operator_or_customer",
            "limit": "Automation cannot bypass CAPTCHA, OTP, MFA, issuer 3DS, email verification, or customer challenge screens.",
            "unlock": "Request provider-side frictionless/exemption handling where allowed; otherwise the human owner completes the challenge inside the provider or issuer page.",
        },
        {
            "id": "real_card_authorization",
            "owner": "customer_provider_issuer",
            "limit": "Checkout URL creation cannot prove a real card charge; only the hosted provider and issuer can authorize it.",
            "unlock": "A real provider order/payment reaches a successful authorized or settled state.",
        },
        {
            "id": "wallet_receipt_proof",
            "owner": "provider_blockchain_wallet",
            "limit": "BeastBrain cannot claim crypto receipt without a provider settlement event, transaction hash, or wallet/balance proof on the correct network.",
            "unlock": "Record a verified provider settlement event and on-chain or wallet receipt proof.",
        },
        {
            "id": "production_secret_install",
            "owner": "operator",
            "limit": "Production provider values must not be pasted into chat or public records; they must be installed through Secret Manager or an equivalent secret path.",
            "unlock": "Operator mounts real production values, deploys, and reruns the live smoke checks.",
        },
    ]
    next_actions = [
        "Wait for Onramper, Alchemy Pay, Guardarian, Wert, or UAE payment-link provider reply with official onboarding/approval path.",
        "Ask the approved provider for the lowest-friction lawful checkout: 3DS2 frictionless/risk-based authentication, eligible exemption requests, wallet buttons, and MIT/card-on-file only after first consent.",
        "Operator completes legitimate dashboard account steps, KYB document upload, terms, subscription, CAPTCHA, OTP, or email verification where required.",
        "After approval, mount real production provider values through Secret Manager without pasting them in chat.",
        "Redeploy BeastBrain and rerun /api/card-to-crypto/status plus a hosted checkout/order smoke.",
        "Run one real provider-side payment and record webhook/order status plus wallet/chain receipt proof before marking 100%.",
    ]
    return {
        "definition_completeness_percent": 100,
        "current_readiness_percent": round((met_weight / len(criteria)) * 100),
        "is_100_percent_live": is_100_percent_live,
        "current_status": "100_percent_live" if is_100_percent_live else "not_100_percent_yet",
        "claim_rule": "Only say card-to-crypto is 100% when every criterion is met; checkout URL creation alone is not enough.",
        "definition": "100% means provider-approved production credentials, hosted checkout/order creation, fixed wallet/network settlement, verified webhook/order status, real card authorization, and confirmed crypto receipt in the BeastBrain wallet.",
        "criteria": criteria,
        "blocking_deformities": blockers,
        "diformity_report": blockers,
        "automation_limits": automation_limits,
        "next_actions_to_reach_100": next_actions,
        "requested_gateways_pending": requested_gateways,
        "recorded_proof_summary": recorded_proof_summary,
    }


def _kyc_gateway_readiness() -> dict[str, Any]:
    configured = bool(os.getenv("SUMSUB_APP_TOKEN", "").strip() and os.getenv("SUMSUB_SECRET_KEY", "").strip())
    return {
        "provider": "sumsub",
        "real_trade_active": configured,
        "status_color": "green" if configured else "red",
        "real_trade_reason": (
            "Configured with SUMSUB_APP_TOKEN and SUMSUB_SECRET_KEY."
            if configured else
            "Inactive until SUMSUB_APP_TOKEN and SUMSUB_SECRET_KEY are mounted."
        ),
    }


@app.get("/api/card-usage/options")
def get_card_usage_options():
    gateways = []
    for gateway in get_real_card_onramps():
        if gateway["id"] == "worldpay_hpp":
            continue
        enriched = dict(gateway)
        enriched.update(_real_card_gateway_readiness(gateway["id"]))
        enriched["no_kyc_limit"] = non_kyc_limits_with_usd().get(gateway["id"], {"aed": 0, "usd": 0.0})
        gateways.append(enriched)
    no_kyc_limits = non_kyc_limits_with_usd()
    return {
        "lane": "card_usage_lock",
        "default_gateway": "moonpay",
        "default_lock_gateway": "moonpay",
        "default_pay_gateway": "moonpay",
        "mit_lock_boundary": "Worldpay is removed from BeastBrain card-lock/autopay. Card usage lock now creates provider-hosted Onramper-backed checkout/consent intents; it is not silent MIT auto-debit.",
        "removed_gateways": ["worldpay_hpp"],
        "active_lock_gateways": [
            gateway["id"]
            for gateway in gateways
            if gateway.get("lock_card_active") and gateway.get("real_trade_active")
        ],
        "dashboard_button": {
            "label": "Card Usage Lock",
            "ui_route": "/payments#card",
            "api_route": "/api/card-usage/lock",
        },
        "card_use_modes": get_card_use_modes(),
        "limits": {
            "kyc_tiers": kyc_tiers_with_usd(),
            "no_kyc": no_kyc_limits,
            "default_no_kyc": no_kyc_limits.get("moonpay") or no_kyc_limits.get("onramper"),
        },
        "gateways": gateways,
        "permanent_wallet_configured_networks": configured_permanent_wallet_networks(),
        "real_money_boundary": _hosted_card_real_money_boundary(),
        "message": "Use hosted provider checkout for real card money. BeastBrain never collects card number, expiry, CVV, OTP, or bank credentials.",
    }


@app.get("/api/card-to-crypto/status")
def card_to_crypto_status():
    gateway_data = get_real_card_payment_gateways()
    active_gateways = [
        gateway["id"]
        for gateway in gateway_data["gateways"]
        if gateway.get("real_trade_active")
    ]
    hundred_percent = _card_to_crypto_hundred_percent_readiness(gateway_data, active_gateways)
    friction_policy = _card_to_crypto_merchant_friction_reduction_policy()
    return {
        "status": "active_hosted_checkout",
        "page_url": "/card-to-crypto",
