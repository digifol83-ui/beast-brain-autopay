@asynccontextmanager
async def _lifespan(app: FastAPI):
    # FastMCP needs its session manager running for streamable HTTP transport.
    # Under pytest we disable this to avoid hanging on external deps.
    if _DISABLE_MCP:
        yield
        return
    from mcp_server import mcp as _mcp
    async with _mcp.session_manager.run():
        yield


app = FastAPI(title="brain-api", version="1.1", lifespan=None if _DISABLE_MCP else _lifespan)

# Mount MCP streamable-HTTP transport. The endpoint is at /mcp/mcp (FastMCP
# serves at /mcp inside its own app; Starlette mount adds the /mcp prefix).
#
# Under pytest we skip importing/mounting this entirely; some MCP internals may
# start background machinery on import/startup and block TestClient.
if not _DISABLE_MCP:
    from mcp_server import mcp as _mcp
    app.mount("/mcp", _mcp.streamable_http_app())
app.include_router(onramp_router)
app.include_router(kyc_router)
app.include_router(project_router)
app.include_router(routes_chatimg_autopay.router)

# Initialize integration framework
_integration_registry = IntegrationRegistry("integrations_config.json")
_situation_router = SituationRouter(_integration_registry)

