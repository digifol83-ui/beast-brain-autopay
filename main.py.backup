class Attachment(BaseModel):
    name: str
    mime: str
    data_b64: str  # raw base64 (no data: prefix). Cap enforced server-side.


class ChatIn(BaseModel):
    message: str
    session_id: str | None = None
    reasoner: str | None = None  # 'claude' | 'gemini' | 'codex' | 'venice' | None
    attachments: list[Attachment] = []
    enabled_tools: list[str] | None = None  # subset of plugin names; None = all enabled


class ResearchIn(BaseModel):
    topic: str
    reasoner: str | None = None
    save_digest: bool = True


class ScribdSearchIn(BaseModel):
    query: str
    max_results: int = 10


class ScribdLookupIn(BaseModel):
    url: str


class ActivityIn(BaseModel):
    prompt: str
    activity_type: str  # "build_site" | "create_bot" | "edit_code" | "deploy"
    context: dict | None = None
    project_path: str | None = None


class WorkflowIn(BaseModel):
    prompt: str  # Natural language task description
    use_ollama_planner: bool = True


class DocumentPrepareIn(BaseModel):
    message: str = ""
    operator_note: str = ""


class VinDecodeIn(BaseModel):
    vin: str = Field(..., description="VIN or loose VIN-like input to decode.")
    use_api: bool = Field(True, description="Use NHTSA vPIC fallback when local decode is incomplete.")
    timeout_seconds: float = Field(6.0, ge=1.0, le=20.0, description="NHTSA lookup timeout.")


def _html_with_document_cookie(path: Path, fallback_html: str, request: Request) -> HTMLResponse:
    if not path.exists():
        response = HTMLResponse(fallback_html)
    else:
        response = HTMLResponse(path.read_text())
    token = request.query_params.get("token")
    if token:
        response.set_cookie(
            "beastbrain_documents_token",
            token,
            max_age=60 * 60 * 24 * 30,
            secure=True,
            httponly=True,
            samesite="lax",
        )
    return response


@app.get("/", response_class=HTMLResponse)
def ui(request: Request):
