def _stripe_webhook_configured() -> bool:
    return os.getenv("STRIPE_WEBHOOK_SECRET", "").startswith("whsec_")


def _verify_stripe_webhook_signature(raw_body: bytes, signature_header: str | None) -> None:
    secret = os.getenv("STRIPE_WEBHOOK_SECRET", "")
    if not secret.startswith("whsec_"):
        raise HTTPException(503, "STRIPE_WEBHOOK_SECRET is not configured")
    if not signature_header:
        raise HTTPException(400, "missing Stripe-Signature header")

    parts: dict[str, list[str]] = {}
    for item in signature_header.split(","):
        key, sep, value = item.partition("=")
        if sep and key and value:
            parts.setdefault(key, []).append(value)

    timestamps = parts.get("t") or []
    signatures = parts.get("v1") or []
    if not timestamps or not signatures:
        raise HTTPException(400, "invalid Stripe-Signature header")

    timestamp = timestamps[0]
    try:
        timestamp_seconds = int(timestamp)
    except ValueError:
        raise HTTPException(400, "invalid Stripe-Signature timestamp")

    tolerance = int(os.getenv("STRIPE_WEBHOOK_TOLERANCE_SECONDS", "300"))
    if abs(int(time.time()) - timestamp_seconds) > tolerance:
        raise HTTPException(400, "expired Stripe webhook signature")

    signed_payload = f"{timestamp}.".encode("utf-8") + raw_body
    expected = hmac.new(secret.encode("utf-8"), signed_payload, hashlib.sha256).hexdigest()
    if not any(hmac.compare_digest(expected, value) for value in signatures):
        raise HTTPException(400, "invalid Stripe webhook signature")


def _stripe_removed() -> None:
    raise HTTPException(
        410,
        "STRIPE_REMOVED: BeastBrain Payment Department now uses non-Stripe hosted provider checkouts. "
        "Use /api/payment-department/status, /api/payment-department/card-lock/setup, and "
        "/api/payment-department/settlement/evaluate.",
    )


@app.get("/api/stripe/webhook")
def stripe_webhook_status():
    """Report Stripe webhook readiness without exposing the signing secret."""
    _stripe_removed()


