    return {
        "lock_id": lock_id,
        "status": "cancel_requested",
        "beastbrain_card_storage": "none",
        "next_step": "Cancel or delete the saved card inside the hosted onramp provider account if it was saved there.",
    }


@app.get("/api/gateway-limits")
def get_gateway_limits():
    """Get no-KYC limits for all gateways."""
    gateway_limits = non_kyc_limits_with_usd()
    kyc_tiers = kyc_tiers_with_usd()
    highest = max(NO_KYC_GATEWAY_LIMITS.values())
    return {
        "kyc_tiers_aed": KYC_TIERS,
        "kyc_tiers_usd": {key: value["usd"] for key, value in kyc_tiers.items()},
        "kyc_tiers": kyc_tiers,
        "gateway_limits_aed": NO_KYC_GATEWAY_LIMITS,
        "gateway_limits_usd": {key: value["usd"] for key, value in gateway_limits.items()},
        "gateway_limits": gateway_limits,
        "card_use_modes": get_card_use_modes(),
        "real_money_boundary": _hosted_card_real_money_boundary(),
        "summary": {
            "highest_no_kyc": highest,
            "highest_no_kyc_usd": gateway_limits[[k for k, v in NO_KYC_GATEWAY_LIMITS.items() if v == highest][0]]["usd"],
            "highest_provider": [k for k, v in NO_KYC_GATEWAY_LIMITS.items() if v == highest],
        }
    }


@app.post("/api/plugins/call")
def api_plugins_call(body: PluginCallIn):
    """Dispatch a single tool call. Used by the in-browser Ollama path."""
    import tools as _t
    if body.name not in _t.REGISTRY:
        raise HTTPException(404, f"unknown tool: {body.name}")
    try:
        return _t.call_tool(body.name, body.args or {})
    except Exception as e:
        raise HTTPException(500, f"{type(e).__name__}: {e}")


@app.post("/sessions/new")
def new_session():
    """Create a new session. Returns the session ID."""
    sid = memory.new_session_id()
    session = memory.load(sid)  # Initializes empty session in memory
    memory.save(session)  # Persist to GCS
    return {"session_id": sid}


