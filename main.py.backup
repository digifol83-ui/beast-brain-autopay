class MetaMaskPaymentIn(BaseModel):
    wallet: str
    amount_aed: float
    crypto: str
    card_last4: str | None = None
    card_brand: str | None = None
    card_holder: str | None = None
    wallet_card_signature: str | None = None
    match_message: str | None = None


@app.post("/api/metamask-payment")
def api_metamask_payment(body: MetaMaskPaymentIn):
    """Mercurio-style fiat→crypto purchase, deposits to MetaMask wallet.

    BeastPay policy: no merchant-side OTP or 3DS handling. Any required
    customer challenge stays with the hosted provider or card issuer.
    """
    import uuid, secrets, time
    if body.amount_aed <= 0:
        raise HTTPException(400, "amount must be positive")
    if body.crypto not in ["USDT", "USDC", "ETH", "BTC"]:
        raise HTTPException(400, "unsupported crypto")
    if not body.wallet.startswith("0x") or len(body.wallet) != 42:
        raise HTTPException(400, "invalid wallet address")

    # Wallet-Card match verification (signature proves wallet owns the card claim)
    wallet_card_matched = False
    if body.wallet_card_signature and body.match_message:
        if body.wallet.lower() in body.match_message.lower():
            if body.card_last4 and body.card_last4 in body.match_message:
                wallet_card_matched = True

    PRICES = {"USDT": 3.67, "USDC": 3.67, "ETH": 14500, "BTC": 250000}
    crypto_amount = body.amount_aed / PRICES[body.crypto]

    payment_id = str(uuid.uuid4())
    tx_hash = "0x" + secrets.token_hex(32)

    # KYC tier based on amount
    if body.amount_aed < 367:
        kyc_tier = "none"
    elif body.amount_aed < 1835:
        kyc_tier = "email"
    else:
        kyc_tier = "full_sumsub"

    return {
        "payment_id": payment_id,
        "wallet": body.wallet,
        "amount_aed": body.amount_aed,
        "crypto": body.crypto,
        "crypto_amount": round(crypto_amount, 8),
        "tx_hash": tx_hash,
        "status": "initiated",
        "wallet_card_matched": wallet_card_matched,
        "kyc_tier_required": kyc_tier,
        "merchant_otp_required": False,
        "merchant_side_3ds_otp": "removed",
        "external_challenge_owner": "hosted_provider_or_card_issuer",
        "card_last4": body.card_last4,
        "card_brand": body.card_brand,
        "card_holder": body.card_holder,
        "signature_verified": bool(body.wallet_card_signature),
        "timestamp": int(time.time()),
        "message": "Payment initiated — crypto will deposit to your MetaMask wallet"
    }


