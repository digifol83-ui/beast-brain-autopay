def checkout_lite_payment(body: CheckoutLitePaymentIn):
    """Create a Checkout Lite no-KYC crypto payment address."""
    try:
        response = checkout_lite.create_checkout_lite_payment(
            provider_id=body.provider_id,
            amount_aed=body.amount_aed,
            crypto=body.crypto,
            network=body.network,
            destination_wallet=body.destination_wallet,
            auto_payment=body.auto_payment,
            autopay_cadence=body.autopay_cadence,
            autopay_limit_aed=body.autopay_limit_aed,
        )
        assist = _record_payment_ops_assist_safe(
            source="checkout_lite_payment_created",
            event_type="crypto_payment_address_created",
            provider=body.provider_id,
            payment_id=response.get("payment_id") if isinstance(response, dict) else None,
            amount_aed=body.amount_aed,
            metadata={
                "crypto": body.crypto,
                "network": body.network,
                "auto_payment": body.auto_payment,
                "stripe_role": "not_used_for_checkout_lite_crypto",
            },
        )
        if isinstance(response, dict):
            response["payment_ops_assist"] = assist
        return response
    except ValueError as e:
        raise HTTPException(400, str(e))
    except RuntimeError as e:
        raise HTTPException(502, str(e))
    except httpx.HTTPError as e:
        raise HTTPException(502, f"CryptAPI request failed: {type(e).__name__}: {e}")


@app.api_route("/api/checkout-lite/webhook/cryptapi", methods=["GET", "POST"], response_class=PlainTextResponse)
async def checkout_lite_cryptapi_webhook(request: Request):
    """Receive CryptAPI payment callbacks and acknowledge with *ok*."""
    raw_body = await request.body()
    signature = request.headers.get("x-ca-signature")
    signed_data = str(request.url) if request.method == "GET" else raw_body
    signature_valid = checkout_lite.verify_cryptapi_signature(signed_data, signature)
    signature_mode = os.getenv("CRYPTAPI_WEBHOOK_SIGNATURE_MODE", "required").strip().lower()
    if signature_mode not in {"off", "optional"} and not signature_valid:
        raise HTTPException(401, "invalid CryptAPI signature")

    checkout_lite.parse_cryptapi_webhook(
        dict(request.query_params),
        raw_body,
        request.headers.get("content-type", ""),
    )
    _record_payment_ops_assist_safe(
        source="checkout_lite_cryptapi_webhook",
        event_type="crypto_gateway_callback",
        provider=str(request.query_params.get("provider") or "cryptapi"),
        payment_id=str(request.query_params.get("payment_id") or ""),
        metadata={
            "method": request.method,
            "signature_valid": signature_valid,
            "stripe_role": "not_used_for_crypto_gateway_callback",
        },
    )
    return PlainTextResponse("*ok*")


@app.post("/api/card-locks/{lock_id}/cancel")
