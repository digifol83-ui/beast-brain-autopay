        "amount_aed": body.amount_aed,
        "source_currency": body.source_currency.lower(),
        "crypto": body.crypto.upper(),
        "network": body.network.lower(),
        "wallet_locked": body.lock_wallet_address and bool(body.wallet_address),
        "real_crypto_delivery": "Stripe fulfills crypto delivery only after Stripe onramp approval, customer checks, payment success, and onchain settlement.",
    }


@app.post("/api/stripe/webhook")
async def stripe_webhook(request: Request):
    """Receive verified Stripe events and store minimal reconciliation metadata."""
    _stripe_removed()
    raw_body = await request.body()
    _verify_stripe_webhook_signature(raw_body, request.headers.get("stripe-signature"))

    try:
        event = json.loads(raw_body.decode("utf-8"))
    except json.JSONDecodeError:
        raise HTTPException(400, "invalid Stripe webhook JSON")

    event_id = str(event.get("id") or "")
    event_type = str(event.get("type") or "")
    data = event.get("data") if isinstance(event.get("data"), dict) else {}
    obj = data.get("object") if isinstance(data.get("object"), dict) else {}
    record = {
        "event_id": event_id,
        "event_type": event_type,
        "livemode": bool(event.get("livemode")),
        "created": event.get("created"),
        "object_id": obj.get("id"),
        "object_type": obj.get("object"),
        "status": obj.get("status"),
        "amount": obj.get("amount") or obj.get("amount_received"),
        "currency": obj.get("currency"),
        "received_at": project_store.now_iso(),
    }

    state = project_store.load_state()
    events = state.setdefault("stripe_webhook_events", [])
    if event_id and any(item.get("event_id") == event_id for item in events):
        return {"received": True, "duplicate": True, "event_id": event_id, "event_type": event_type}

    metadata = obj.get("metadata") if isinstance(obj.get("metadata"), dict) else {}
    autopay_id = metadata.get("autopay_id") or obj.get("client_reference_id")
    if event_type == "setup_intent.succeeded" and autopay_id:
        lock = project_store.find_one(state, "stripe_autopay_locks", "autopay_id", autopay_id)
        if lock:
            lock["status"] = "card_locked"
            lock["stripe_customer_id"] = obj.get("customer")
            lock["stripe_payment_method_id"] = obj.get("payment_method")
            lock["setup_intent_id"] = obj.get("id")
            lock["updated_at"] = project_store.now_iso()
    if event_type.startswith("payment_intent.") and autopay_id:
        charge = project_store.find_one(state, "stripe_autopay_charges", "stripe_payment_intent_id", obj.get("id") or "")
        if charge:
            charge["status"] = obj.get("status")
            charge["event_type"] = event_type
            charge["updated_at"] = project_store.now_iso()
            ledger_charge_attempt_id = charge.get("ledger_charge_attempt_id")
            if ledger_charge_attempt_id:
                if event_type == "payment_intent.succeeded":
                    usage_billing.mark_attempt(state, ledger_charge_attempt_id, "paid", obj.get("id"))
                elif event_type == "payment_intent.payment_failed":
                    usage_billing.mark_attempt(state, ledger_charge_attempt_id, "failed", obj.get("id"))
                elif event_type == "payment_intent.requires_action":
                    usage_billing.mark_attempt(state, ledger_charge_attempt_id, "failed", obj.get("id"))
    if hasattr(payment_department, "handle_stripe_payment_event"):
        payment_department.handle_stripe_payment_event(state, event_type, obj)

    payment_ops.record_payment_assist(
        state,
        source="stripe_webhook",
        event_type=event_type or "stripe_event",
        provider="stripe",
        payment_id=obj.get("id") or event_id,
        project_id=metadata.get("project_id"),
        amount_aed=(float(record["amount"]) / 100 if str(record.get("currency") or "").lower() == "aed" and record.get("amount") else None),
        metadata={
            "livemode": record["livemode"],
            "object_type": record["object_type"],
            "status": record["status"],
            "autopay_id": autopay_id,
            "stripe_wallet_used": False,
            "crypto_conversion_owner": "hosted_crypto_payment_gateways",
        },
    )
    events.append(record)
    state["stripe_webhook_events"] = events[-100:]
    project_store.record_activity(state, "stripe_webhook_received", detail=f"{event_type} {event_id}".strip())
    project_store.save_state(state)

    return {
        "received": True,
        "duplicate": False,
        "event_id": event_id,
        "event_type": event_type,
        "stored_raw_card_data": False,
    }


