@app.get("/api/dex/quote")
def dex_quote(from_token: str = "0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174", 
              to_token: str = "0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270",
              amount: str = "1000000"):
    """Get DEX swap quote from 1inch (Polygon)."""
    import requests
    key = os.getenv("ONEINCH_API_KEY")
    if not key:
        raise HTTPException(500, "ONEINCH_API_KEY not configured")
    
    resp = requests.get(
        f"https://api.1inch.dev/swap/v6.0/137/quote",
        params={"src": from_token, "dst": to_token, "amount": amount},
        headers={"Authorization": f"Bearer {key}"},
        timeout=10
    )
    if resp.status_code != 200:
        raise HTTPException(resp.status_code, f"1inch error: {resp.text}")
    
    return {"status": "live", "quote": resp.json(), "source": "1inch_polygon"}


