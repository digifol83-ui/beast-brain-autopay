def _record_payment_ops_assist_safe(**kwargs) -> dict[str, Any] | None:
    if os.getenv("BRAIN_DISABLE_MCP") == "1" and not os.getenv("BRAIN_PROJECTS_STORE_PATH"):
        return {
            "assist_recorded": False,
            "reason": "test_runtime_without_project_store",
            "stripe_wallet_used": False,
            "crypto_conversion_owner": "hosted_crypto_payment_gateways",
        }
    try:
        state = project_store.load_state()
        assist = payment_ops.record_payment_assist(state, **kwargs)
        project_store.save_state(state)
        return assist
    except Exception as exc:
        return {
            "assist_recorded": False,
            "error": f"{type(exc).__name__}: {exc}",
            "stripe_wallet_used": False,
            "crypto_conversion_owner": "hosted_crypto_payment_gateways",
        }


def _create_project_usage_charge_attempt(
    state: dict[str, Any],
    *,
    project_id: str,
    autopay_id: str | None = None,
) -> dict[str, Any] | None:
    if usage_billing.active_charge_attempts(state, project_id):
        return None

    unbilled_points = usage_billing.current_unbilled_points(state, project_id)
    if unbilled_points < 100:
        return None

    if not usage_billing.auto_charge_enabled():
        return None

    credentials = stripe_gateway.credential_status()
    if not (credentials["secret_key"] and credentials["publishable_key"] and credentials["webhook_secret"]):
        return None

    lock = usage_billing.find_autopay_lock(state, project_id, autopay_id)
    if not lock or lock.get("status") != "card_locked":
        return None

    customer_id = lock.get("stripe_customer_id")
    payment_method_id = lock.get("stripe_payment_method_id")
    if not customer_id or not payment_method_id:
        return None

    customer_ref = lock.get("customer_id") or lock.get("customer_email") or customer_id
    charge_attempt_id = project_store.new_id("usage_charge")
    idempotency_key = f"beastbrain-usage-{project_id}-{charge_attempt_id}"
    intent = stripe_gateway.create_off_session_payment_intent(
        autopay_id=lock["autopay_id"],
        amount_aed=100,
        customer_id=customer_id,
        payment_method_id=payment_method_id,
        project_id=project_id,
        wallet_address=lock.get("wallet_address"),
        crypto=lock.get("crypto") or "USDC",
        network=lock.get("network") or "polygon",
        idempotency_key=idempotency_key,
    )
    attempt = {
        "charge_attempt_id": charge_attempt_id,
        "project_id": project_id,
        "customer_id": customer_ref,
        "autopay_id": lock["autopay_id"],
        "provider": "stripe",
        "provider_payment_id": intent.get("id"),
        "charged_points": 100,
        "amount_aed": 100,
        "currency": "aed",
        "billing_status": "pending_charge",
        "stripe_status": intent.get("status"),
        "idempotency_key": idempotency_key,
        "created_at": project_store.now_iso(),
        "updated_at": project_store.now_iso(),
    }
    state.setdefault("project_usage_charge_attempts", []).append(attempt)
    state.setdefault("stripe_autopay_charges", []).append({
        "charge_id": project_store.new_id("stripe_charge"),
        "autopay_id": lock["autopay_id"],
        "ledger_charge_attempt_id": charge_attempt_id,
        "stripe_payment_intent_id": intent.get("id"),
        "amount_aed": 100,
        "currency": "aed",
        "status": intent.get("status"),
        "created_at": project_store.now_iso(),
    })
    usage_billing.append_charge_state(
        state,
        project_id=project_id,
        customer_id=customer_ref,
        charge_attempt_id=charge_attempt_id,
        billing_status="pending_charge",
        charged_points=100,
        provider_payment_id=intent.get("id"),
    )
    project_store.record_activity(state, "project_usage_charge_pending", project_id=project_id, detail=intent.get("id"))
    return attempt


@app.get("/api/projects/{project_id}/usage/ledger")
async def project_usage_ledger(project_id: str):
    state = project_store.load_state()
    return {
        "project_id": project_id,
        "summary": usage_billing.usage_summary(state, project_id),
        "ledger": usage_billing.project_entries(state, project_id),
        "charge_attempts": [
            attempt
            for attempt in state.get("project_usage_charge_attempts", [])
            if attempt.get("project_id") == project_id
        ],
    }


@app.post("/api/projects/{project_id}/usage/evaluate")
async def project_usage_evaluate(project_id: str, body: ProjectUsageEvaluateIn):
    state = project_store.load_state()
    try:
        charge_attempt = _create_project_usage_charge_attempt(state, project_id=project_id, autopay_id=body.autopay_id)
    except stripe_gateway.StripeConfigError as exc:
        raise HTTPException(503, str(exc))
    except stripe_gateway.StripeAPIError as exc:
        raise HTTPException(exc.status_code if exc.status_code < 600 else 502, str(exc))

    status = "pending_charge_created" if charge_attempt else "no_charge_due"
    project_store.save_state(state)
    return {
        "status": status,
        "project_id": project_id,
        "summary": usage_billing.usage_summary(state, project_id),
        "charge_attempt": charge_attempt,
        "real_auto_deduct_active": usage_billing.auto_charge_enabled(),
    }


@app.post("/api/projects/{project_id}/usage/events")
async def project_usage_event(project_id: str, body: ProjectUsageEventIn):
    state = project_store.load_state()
    try:
        points = usage_billing.calculate_points(
            body.action_performed,
            metadata=body.metadata,
            points_accrued=body.points_accrued,
        )
    except ValueError as exc:
        raise HTTPException(400, str(exc))

    customer_id = body.customer_id or project_id
    duplicate_event = (
        usage_billing.duplicate_usage_event(state, body.usage_event_id)
        if body.usage_event_id
        else None
    )
    ledger_entry = usage_billing.append_usage_event(
        state,
        project_id=project_id,
        customer_id=customer_id,
        action_performed=body.action_performed,
        usage_event_id=body.usage_event_id,
        points=points,
        metadata=body.metadata,
    )

    charge_attempt = None
    if body.attempt_auto_charge and not duplicate_event:
        try:
            charge_attempt = _create_project_usage_charge_attempt(state, project_id=project_id, autopay_id=body.autopay_id)
        except stripe_gateway.StripeConfigError as exc:
            raise HTTPException(503, str(exc))
        except stripe_gateway.StripeAPIError as exc:
            raise HTTPException(exc.status_code if exc.status_code < 600 else 502, str(exc))

    project_store.record_activity(state, "project_usage_event_recorded", project_id=project_id, detail=ledger_entry.get("usage_event_id"))
    project_store.save_state(state)
    return {
        "status": "duplicate" if duplicate_event else "recorded",
        "project_id": project_id,
        "ledger_entry": ledger_entry,
        "summary": usage_billing.usage_summary(state, project_id),
        "charge_attempt": charge_attempt,
        "real_auto_deduct_active": usage_billing.auto_charge_enabled(),
    }


@app.post("/api/stripe/autopay/setup")
def stripe_autopay_setup(body: StripeAutoPaySetupIn, request: Request):
    """Create a live Stripe-hosted card setup checkout for future auto-payments."""
    _stripe_removed()
    if body.amount_aed <= 0 or body.threshold_aed <= 0:
        raise HTTPException(400, "amount and threshold must be positive")
    autopay_id = stripe_gateway.new_autopay_id()
    base_url = str(request.base_url).rstrip("/")
    success_url = body.success_url or f"{base_url}/payments?stripe_autopay=success&autopay_id={autopay_id}&session_id={{CHECKOUT_SESSION_ID}}"
    cancel_url = body.cancel_url or f"{base_url}/payments?stripe_autopay=cancelled&autopay_id={autopay_id}"
    try:
        session = stripe_gateway.create_setup_checkout_session(
            autopay_id=autopay_id,
            email=body.customer_email.strip(),
            success_url=success_url,
            cancel_url=cancel_url,
            project_id=body.project_id,
            wallet_address=body.wallet_address,
            crypto=body.crypto,
            network=body.network,
            threshold_aed=body.threshold_aed,
            point_value_aed=body.point_value_aed,
        )
    except ValueError as exc:
        raise HTTPException(400, str(exc))
    except stripe_gateway.StripeConfigError as exc:
        raise HTTPException(503, str(exc))
    except stripe_gateway.StripeAPIError as exc:
        raise HTTPException(exc.status_code if exc.status_code < 600 else 502, str(exc))

    state = project_store.load_state()
    lock = {
        "autopay_id": autopay_id,
        "provider": "stripe",
        "status": "setup_checkout_created",
        "project_id": body.project_id,
        "customer_email": body.customer_email.strip(),
        "wallet_address": body.wallet_address,
        "crypto": body.crypto.upper(),
        "network": body.network.lower(),
        "threshold_aed": body.threshold_aed,
        "point_value_aed": body.point_value_aed,
        "checkout_session_id": session.get("id"),
        "created_at": project_store.now_iso(),
        "updated_at": project_store.now_iso(),
    }
    state.setdefault("stripe_autopay_locks", []).append(lock)
    project_store.record_activity(state, "stripe_autopay_setup_created", project_id=body.project_id, detail=autopay_id)
    project_store.save_state(state)

    return {
        "provider": "stripe",
        "status": "checkout_created",
        "autopay_id": autopay_id,
        "checkout_session_id": session.get("id"),
        "checkout_url": session.get("url"),
        "requires_redirect": True,
        "real_card_setup": True,
        "card_data_handled_by": "stripe_checkout",
        "raw_card_data_stored": False,
        "message": "Open checkout_url and complete Stripe-hosted card setup. BeastBrain stores only Stripe IDs after signed webhooks confirm setup.",
    }


@app.post("/api/stripe/autopay/charge")
def stripe_autopay_charge(body: StripeAutoPayChargeIn):
    """Create a real off-session 100 AED Stripe charge against a saved card."""
    _stripe_removed()
    if not body.confirm_real_charge:
        raise HTTPException(400, "confirm_real_charge=true is required before creating a live Stripe debit")
    if body.amount_aed <= 0:
        raise HTTPException(400, "amount_aed must be positive")

    state = project_store.load_state()
    lock = project_store.find_one(state, "stripe_autopay_locks", "autopay_id", body.autopay_id)
    if not lock:
        raise HTTPException(404, "Stripe autopay lock not found")
    if lock.get("status") != "card_locked":
        raise HTTPException(409, "Card setup is not webhook-confirmed yet")
    customer_id = lock.get("stripe_customer_id")
    payment_method_id = lock.get("stripe_payment_method_id")
    if not customer_id or not payment_method_id:
        raise HTTPException(409, "Stripe customer/payment method is not available yet")

    try:
        intent = stripe_gateway.create_off_session_payment_intent(
            autopay_id=body.autopay_id,
            amount_aed=body.amount_aed,
            customer_id=customer_id,
            payment_method_id=payment_method_id,
            project_id=lock.get("project_id"),
            wallet_address=lock.get("wallet_address"),
            crypto=lock.get("crypto") or "USDC",
            network=lock.get("network") or "polygon",
        )
    except ValueError as exc:
        raise HTTPException(400, str(exc))
    except stripe_gateway.StripeConfigError as exc:
        raise HTTPException(503, str(exc))
    except stripe_gateway.StripeAPIError as exc:
        raise HTTPException(exc.status_code if exc.status_code < 600 else 502, str(exc))

    charge = {
        "charge_id": project_store.new_id("stripe_charge"),
        "autopay_id": body.autopay_id,
        "stripe_payment_intent_id": intent.get("id"),
        "amount_aed": body.amount_aed,
        "currency": "aed",
        "status": intent.get("status"),
        "created_at": project_store.now_iso(),
    }
    state.setdefault("stripe_autopay_charges", []).append(charge)
    project_store.record_activity(state, "stripe_autopay_charge_created", project_id=lock.get("project_id"), detail=intent.get("id"))
    project_store.save_state(state)

    return {
        "provider": "stripe",
        "status": intent.get("status"),
        "payment_intent_id": intent.get("id"),
        "amount_aed": body.amount_aed,
        "real_money_debit_requested": True,
        "webhook_required_to_mark_paid": True,
        "crypto_delivery": "Use /api/stripe/onramp/session after payment success if Stripe crypto onramp is approved, or use Onramper-backed hosted checkout for USDT.",
    }


@app.post("/api/stripe/onramp/session")
def stripe_onramp_session(body: StripeOnrampSessionIn, request: Request):
    """Create a Stripe crypto onramp session for direct fiat-to-crypto delivery."""
    _stripe_removed()
    if body.amount_aed <= 0:
        raise HTTPException(400, "amount_aed must be positive")
    try:
        session = stripe_gateway.create_crypto_onramp_session(
            amount_aed=body.amount_aed,
            source_currency=body.source_currency,
            crypto=body.crypto,
            network=body.network,
            wallet_address=body.wallet_address,
            lock_wallet_address=body.lock_wallet_address,
            customer_ip_address=request.client.host if request.client else None,
        )
    except ValueError as exc:
        raise HTTPException(400, str(exc))
    except stripe_gateway.StripeConfigError as exc:
        raise HTTPException(503, str(exc))
    except stripe_gateway.StripeAPIError as exc:
        raise HTTPException(exc.status_code if exc.status_code < 600 else 502, str(exc))

    return {
        "provider": "stripe_onramp",
        "status": session.get("status"),
        "onramp_session_id": session.get("id"),
        "redirect_url": session.get("redirect_url"),
        "requires_redirect": bool(session.get("redirect_url")),
