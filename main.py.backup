@app.post("/api/card-usage/lock")
def create_card_usage_lock(body: CardUsageLockIn):
    if body.amount_aed <= 0:
        raise HTTPException(400, "amount must be positive")
    if body.amount_aed < 25:
        raise HTTPException(400, "amount must be at least 25 AED for hosted card usage lock")

    if body.gateway_id == "worldpay_hpp":
        raise HTTPException(400, "Worldpay has been removed from BeastBrain card-lock/autopay. Use MoonPay/Onramper or another active hosted provider.")
    if body.gateway_id not in HOSTED_CARD_USAGE_LOCK_PROVIDER_IDS:
        raise HTTPException(400, f"{body.gateway_id} is not enabled for hosted card usage lock")
    readiness = _real_card_gateway_readiness(body.gateway_id)
    if not readiness.get("real_trade_active"):
        raise HTTPException(400, f"{body.gateway_id} is not verified active for hosted card usage lock: {readiness.get('real_trade_reason')}")

    gateway_limit = NO_KYC_GATEWAY_LIMITS.get(body.gateway_id, 0)
    if body.enforce_no_kyc:
        if gateway_limit <= 0:
            raise HTTPException(400, f"{body.gateway_id} does not publish a BeastBrain no-KYC limit; provider verification may apply")
        if body.amount_aed > gateway_limit:
            raise HTTPException(
                400,
                f"amount exceeds {body.gateway_id} no-KYC limit of {gateway_limit} AED",
            )

    payment = gateway_payment(GatewayPaymentIn(
        gateway_id=body.gateway_id,
        amount_aed=body.amount_aed,
        crypto=body.crypto,
        network=body.network,
        wallet_address=body.wallet_address,
        lock_card_for_auto_payments=True,
        autopay_cadence=body.autopay_cadence,
        autopay_limit_aed=body.autopay_limit_aed if body.autopay_limit_aed is not None else body.amount_aed,
    ))
    payment.update({
        "lane": "card_usage_lock",
        "card_use_mode": "hosted_card_usage_lock",
        "customer_reference": body.customer_reference,
        "project_id": body.project_id,
        "raw_card_data_stored": False,
        "provider_hosted_checkout_required": True,
        "no_kyc_enforced": body.enforce_no_kyc,
        "no_kyc_limit": non_kyc_limits_with_usd().get(body.gateway_id, {"aed": gateway_limit, "usd": 0.0}),
        "real_money_boundary": _hosted_card_real_money_boundary(),
        "one_click_deduction_boundary": "Future usage charging stays provider-hosted. BeastBrain creates checkout/consent intents and cannot silently debit a bank account.",
        "mit_removed_gateway": "worldpay_hpp",
        "lock_card_mode": readiness.get("lock_card_mode", "hosted_provider_checkout_intent"),
    })
    return payment


