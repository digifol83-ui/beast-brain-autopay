@app.get("/api/payment-gateways/real-card")
def get_real_card_payment_gateways():
    """Real hosted card-to-crypto onramps, excluding Transak and Stripe."""
    gateways = []
    for gateway in get_real_card_onramps():
        enriched = dict(gateway)
        enriched.update(_real_card_gateway_readiness(gateway["id"]))
        gateways.append(enriched)
    return {
        "gateways": gateways,
        "excluded": ["transak", "stripe"],
        "default_gateway": "onramper",
        "note": "Card details are handled by hosted onramp providers, not BeastBrain.",
        "kyc_verification": _kyc_gateway_readiness(),
    }


ONRAMPER_BACKED_CARD_IDS = {
    "onramper",
    "moonpay",
    "simplex",
    "mercuryo",
    "moonpay_tw",
    "simplex_tw",
    "mercuryo_tw",
    "coinbase_onramp",
    "banxa",
    "ramp_network",
    "changenow",
    "moonpay_phantom",
    "ramp_phantom",
}
HOSTED_CARD_USAGE_LOCK_PROVIDER_IDS = ONRAMPER_BACKED_CARD_IDS | {
    "alchemy_pay",
    "guardarian",
    "nexapay",
    "wert",
}


def _real_card_gateway_readiness(gateway_id: str) -> dict[str, Any]:
    if gateway_id in ONRAMPER_BACKED_CARD_IDS:
        if gateway_id == "ramp_network":
            ramp_api_key = os.getenv("RAMP_HOST_API_KEY", "").strip() or os.getenv("RAMP_API_KEY", "").strip()
            has_key = bool(ramp_api_key)
            return {
                "real_trade_active": True,
                "status_color": "yellow" if not has_key else "green",
                "real_trade_reason": (
                    "Active through Ramp Network public handoff; email/wallet prefill requires RAMP_HOST_API_KEY."
                    if not has_key else
                    "Configured with RAMP_HOST_API_KEY for hosted widget with email/wallet prefill."
                ),
                "lock_card_active": True,
                "lock_card_mode": "hosted_provider_checkout_intent",
                "real_auto_debit_enabled": False,
            }
        if gateway_id == "banxa":
            return {
                "real_trade_active": True,
                "status_color": "green",
                "real_trade_reason": "Active through hosted Banxa checkout; provider KYC may still apply to the buyer.",
                "lock_card_active": True,
                "lock_card_mode": "hosted_provider_checkout_intent",
                "real_auto_debit_enabled": False,
            }
        return {
            "real_trade_active": True,
            "status_color": "green",
            "real_trade_reason": "Active through hosted Onramper card checkout; provider KYC may still apply to the buyer.",
            "lock_card_active": True,
            "lock_card_mode": "hosted_provider_checkout_intent",
            "real_auto_debit_enabled": False,
        }
    if gateway_id == "alchemy_pay":
        configured = bool(os.getenv("ALCHEMYPAY_APP_ID", "").strip() and os.getenv("ALCHEMYPAY_APP_SECRET", "").strip())
        return {
            "real_trade_active": configured,
            "status_color": "green" if configured else "red",
            "real_trade_reason": (
                "Configured with ALCHEMYPAY_APP_ID and ALCHEMYPAY_APP_SECRET for signed hosted checkout."
                if configured else
                "Inactive until ALCHEMYPAY_APP_ID and ALCHEMYPAY_APP_SECRET are mounted."
            ),
            "lock_card_active": configured,
            "lock_card_mode": "hosted_provider_checkout_intent",
            "real_auto_debit_enabled": False,
        }
    if gateway_id == "guardarian":
        api_key = os.getenv("GUARDARIAN_API_KEY", "").strip()
        configured = bool(api_key and not api_key.startswith(("YOUR_", "REPLACE", "test_")))
        return {
            "real_trade_active": configured,
            "status_color": "green" if configured else "red",
            "real_trade_reason": (
                "Configured with GUARDARIAN_API_KEY for provider-hosted transaction creation."
                if configured else
                "Inactive until Guardarian approves the partner account and GUARDARIAN_API_KEY is mounted."
            ),
            "lock_card_active": configured,
            "lock_card_mode": "hosted_provider_checkout_intent",
            "real_auto_debit_enabled": False,
        }
    if gateway_id == "nexapay":
        configured = bool(os.getenv("NEXAPAY_PUBLIC_KEY", "").strip() and os.getenv("NEXAPAY_MERCHANT_ID", "").strip())
        return {
            "real_trade_active": configured,
            "status_color": "green" if configured else "red",
            "real_trade_reason": (
                "Configured with NEXAPAY_PUBLIC_KEY and NEXAPAY_MERCHANT_ID."
                if configured else
                "Inactive until NEXAPAY_PUBLIC_KEY and NEXAPAY_MERCHANT_ID are mounted."
            ),
            "lock_card_active": configured,
            "lock_card_mode": "hosted_provider_checkout_intent",
            "real_auto_debit_enabled": False,
        }
    if gateway_id == "wert":
        configured = bool(os.getenv("WERT_PARTNER_ID", "").strip() and os.getenv("WERT_API_KEY", "").strip())
        return {
            "real_trade_active": configured,
            "status_color": "green" if configured else "red",
            "real_trade_reason": (
                "Configured with WERT_PARTNER_ID and WERT_API_KEY for hosted widget sessions."
                if configured else
                "Inactive until WERT_PARTNER_ID and WERT_API_KEY are mounted."
            ),
            "lock_card_active": configured,
            "lock_card_mode": "hosted_provider_checkout_intent",
            "real_auto_debit_enabled": False,
        }
    if gateway_id == "worldpay_hpp":
        entity = os.getenv("WORLDPAY_MERCHANT_ENTITY", "").strip()
        configured = bool(
            os.getenv("WORLDPAY_USERNAME", "").strip()
            and os.getenv("WORLDPAY_PASSWORD", "").strip()
            and valid_worldpay_merchant_entity(entity)
        )
        return {
            "real_trade_active": configured,
            "status_color": "green" if configured else "red",
            "real_trade_reason": (
                "Configured for Worldpay Access Hosted Payment Pages, but removed from BeastBrain card-lock/autopay lane."
                if configured else
                "Removed from BeastBrain card-lock/autopay lane. Worldpay credentials are also inactive until a real merchant setup is mounted."
            ),
            "lock_card_active": False,
            "lock_card_mode": "disabled",
            "real_auto_debit_enabled": False,
        }
    return {
        "real_trade_active": False,
        "status_color": "red",
        "real_trade_reason": "Catalog entry only; no real hosted checkout path is configured for this deployment.",
        "lock_card_active": False,
    }


def _hosted_card_real_money_boundary() -> dict[str, Any]:
    return {
        "raw_card_data_stored": False,
        "raw_card_data_handled_by": "hosted_provider_checkout",
        "beastbrain_card_storage": "none",
        "provider_hosted_checkout_required": True,
        "kyc_aml_bypass": False,
        "silent_bank_debit": False,
        "real_money_condition": "Provider credentials, production approval, supported region, user consent, issuer approval, KYC/AML checks, payment success, and onchain settlement must all pass.",
    }


