@app.get("/api/coinremitter/status")
async def coinremitter_status_api():
    """Public CoinRemitter status (no secrets exposed)."""
    return _coinremitter.public_status()


@app.post("/api/coinremitter/webhook")
async def coinremitter_webhook(request: Request):
    """CoinRemitter payment webhook receiver."""
    form = await request.form()
    form_data = dict(form)
    if not _coinremitter.verify_webhook(form_data):
        raise HTTPException(400, "invalid CoinRemitter webhook signature")
    event = _coinremitter.parse_webhook(form_data)
    return {"status": "ok", "event": event}


