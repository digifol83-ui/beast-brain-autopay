@app.get("/scribd", response_class=HTMLResponse)
def scribd_page():
    if not SCRIBD_UI_PATH.exists():
        return HTMLResponse("<h1>Scribd Lookup</h1><p>UI not built.</p>")
    return HTMLResponse(SCRIBD_UI_PATH.read_text())


@app.post("/tools/scribd/search")
def tools_scribd_search(body: ScribdSearchIn):
    if not body.query.strip():
        raise HTTPException(400, "query required")
    return _scribd.search(body.query, body.max_results)


@app.post("/tools/scribd/lookup")
def tools_scribd_lookup(body: ScribdLookupIn):
    if not body.url.strip():
        raise HTTPException(400, "url required")
    return _scribd.lookup(body.url)


@app.get("/tools/scribd/cache")
def tools_scribd_cache(limit: int = 30):
    return _scribd.list_cached_queries(limit=limit)


@app.get("/tools/scribd/cache/{date}/{name}")
def tools_scribd_cache_read(date: str, name: str):
    return _scribd.read_cached_query(f"{date}/{name}")


