@app.post("/api/payment-department/card-lock/setup")
async def payment_department_card_lock_setup(body: PaymentDepartmentCardLockSetupIn):
    state = project_store.load_state()
    try:
        amount_aed = payment_department.CHARGE_INCREMENT_AED
        if round(float(body.amount_aed), 2) != amount_aed:
            raise ValueError("Payment Department card locks are fixed at 100 AED")
        card_lock_intent_id = project_store.new_id("dept_lock")
        permanent_wallet = None
        effective_wallet = body.wallet_address
        effective_network = body.network
        permanent_wallet_used = False
        if not effective_wallet:
            permanent_wallet = resolve_permanent_wallet(body.crypto, body.network)
            effective_wallet = permanent_wallet["wallet_address"]
            effective_network = permanent_wallet["network"]
            permanent_wallet_used = bool(effective_wallet)
        checkout = build_hosted_card_checkout(
            gateway_id=body.gateway_id,
            amount_aed=amount_aed,
            crypto=body.crypto,
            wallet_address=effective_wallet,
            network=effective_network,
            payment_id=card_lock_intent_id,
            lock_card_for_auto_payments=True,
            autopay_cadence=body.autopay_cadence,
            autopay_limit_aed=body.autopay_limit_aed,
        )
        record = payment_department.record_card_lock_intent(
            state,
            card_lock_intent_id=card_lock_intent_id,
            gateway_id=body.gateway_id,
            checkout=checkout,
            project_id=body.project_id,
            customer_email=body.customer_email.strip() if body.customer_email else None,
            amount_aed=amount_aed,
            crypto=body.crypto,
            network=effective_network,
            wallet_address=effective_wallet,
            autopay_cadence=body.autopay_cadence,
            autopay_limit_aed=body.autopay_limit_aed,
        )
    except ValueError as exc:
        raise HTTPException(400, str(exc))

    project_store.save_state(state)
    return {
        "department": "payment_department",
        "status": payment_department.CARD_LOCK_STATUS,
        "blocked": False,
        "provider": body.gateway_id,
        "gateway_id": body.gateway_id,
        "card_lock_intent_id": card_lock_intent_id,
        "payment_id": checkout.get("payment_id"),
        "checkout_url": checkout.get("checkout_url"),
        "redirect_url": checkout.get("checkout_url"),
        "requires_redirect": True,
        "amount_aed": amount_aed,
        "crypto": record["crypto"],
        "network": record["network"],
        "wallet_address": effective_wallet,
        "permanent_wallet_used": permanent_wallet_used,
        "permanent_wallet_source": permanent_wallet["source"] if permanent_wallet_used and permanent_wallet else None,
        "checkout_provider": checkout.get("checkout_provider"),
        "allowed_onramps": checkout.get("allowed_onramps"),
        "wallet_prefilled": checkout.get("wallet_prefilled"),
        "wallet_prefill_requires": checkout.get("wallet_prefill_requires"),
        "api_key_configured": checkout.get("api_key_configured"),
        "card_data_handled_by": checkout.get("card_data_handled_by", "hosted_onramp_provider"),
        "raw_card_data_stored": False,
        "policy": payment_department.policy(),
        "card_lock": record,
        "settlement_evaluate_route": "/api/payment-department/settlement/evaluate",
        "message": "Open the hosted provider checkout to authorize the 100 AED card-to-crypto flow. BeastBrain does not collect or process merchant-side OTP or 3DS; provider approval and payment success remain external.",
    }


@app.post("/api/payment-department/settlement/evaluate")
async def payment_department_settlement_evaluate(body: PaymentDepartmentSettlementEvaluateIn):
    state = project_store.load_state()
    try:
        amount_aed = payment_department.CHARGE_INCREMENT_AED
        if round(float(body.amount_aed), 2) != amount_aed:
            raise ValueError("Payment Department only creates 100 AED hosted crypto purchase checkouts")
        card_lock_intent_id = body.card_lock_intent_id or body.autopay_id
        lock = payment_department.find_card_lock_intent(
            state,
            project_id=body.project_id,
            card_lock_intent_id=card_lock_intent_id,
        )
        effective_wallet = body.wallet_address or (lock or {}).get("wallet_address")
        effective_network = body.network or (lock or {}).get("network")
        permanent_wallet = None
        permanent_wallet_used = False
        if not effective_wallet:
            permanent_wallet = resolve_permanent_wallet(body.crypto, effective_network)
            effective_wallet = permanent_wallet["wallet_address"]
            effective_network = permanent_wallet["network"]
            permanent_wallet_used = bool(effective_wallet)
        settlement_id = project_store.new_id("dept_settle")
        checkout = build_hosted_card_checkout(
            gateway_id=body.gateway_id,
            amount_aed=amount_aed,
            crypto=body.crypto,
            wallet_address=effective_wallet,
            network=effective_network,
            payment_id=settlement_id,
            lock_card_for_auto_payments=True,
            autopay_cadence="on_demand",
            autopay_limit_aed=amount_aed,
        )
        settlement = payment_department.record_settlement_checkout(
            state,
            settlement_id=settlement_id,
            gateway_id=body.gateway_id,
            checkout=checkout,
            project_id=body.project_id,
            card_lock_intent_id=card_lock_intent_id,
            amount_aed=amount_aed,
            crypto=body.crypto,
            network=effective_network,
            wallet_address=effective_wallet,
        )
    except ValueError as exc:
        raise HTTPException(400, str(exc))

    project_store.save_state(state)
    return {
        "department": "payment_department",
        "status": payment_department.SETTLEMENT_STATUS,
        "blocked": False,
        "provider": body.gateway_id,
        "gateway_id": body.gateway_id,
        "checkout_url": checkout.get("checkout_url"),
        "redirect_url": checkout.get("checkout_url"),
        "requires_redirect": True,
        "amount_aed": amount_aed,
        "crypto": settlement["crypto"],
        "network": settlement["network"],
        "wallet_address": effective_wallet,
        "permanent_wallet_used": permanent_wallet_used,
        "permanent_wallet_source": permanent_wallet["source"] if permanent_wallet_used and permanent_wallet else None,
        "checkout_provider": checkout.get("checkout_provider"),
        "allowed_onramps": checkout.get("allowed_onramps"),
        "wallet_prefilled": checkout.get("wallet_prefilled"),
        "wallet_prefill_requires": checkout.get("wallet_prefill_requires"),
        "api_key_configured": checkout.get("api_key_configured"),
        "auto_debit_model": "provider_hosted_checkout_per_100_aed",
        "policy": payment_department.policy(),
        "settlement": settlement,
        "crypto_delivery": "Provider-hosted checkout handles the card debit and crypto deposit. BeastBrain does not bypass KYC, OTP, 3DS, issuer, or onchain settlement checks.",
    }


