    return {"sessions": memory.list_sessions(limit=limit)}


@app.get("/sessions/{sid}")
def session_detail(sid: str):
    s = memory.load(sid)
    return s


@app.post("/run-research-loop")
def run_research(body: ResearchIn):
    """Autonomous one-shot research run. Used by Cloud Scheduler cron."""
    if not body.topic.strip():
        raise HTTPException(400, "topic required")
    sid = memory.new_session_id()
    prompt = (
        f"Research the following topic and produce a concise grounded brief in markdown. "
        f"Use web_search and fetch_url to gather current sources, then summarize the key findings. "
        f"Cite sources as markdown links.\n\nTOPIC: {body.topic}"
    )
    session = memory.load(sid)
    session["messages"].append({"role": "user", "content": prompt})
    session["topic"] = body.topic
    session["mode"] = "autonomous"

    try:
        reply, trace, reasoner_used = llm.run(session["messages"], reasoner=body.reasoner)
    except Exception as e:
        raise HTTPException(502, f"research run failed: {type(e).__name__}: {e}")

    session["messages"].append({"role": "assistant", "content": reply, "trace": trace, "reasoner": reasoner_used})
    memory.save(session)

    out: dict[str, Any] = {
        "session_id": sid,
        "topic": body.topic,
        "reasoner": reasoner_used,
        "tool_calls": len(trace),
        "brief": reply,
    }
    if body.save_digest:
        date_str = datetime.now(timezone.utc).strftime("%Y-%m-%d")
        digest_md = (
            f"# Research Brief — {body.topic}\n\n"
            f"_Generated {datetime.now(timezone.utc).isoformat()} by brain-api ({reasoner_used})_\n\n"
            f"{reply}\n\n"
            f"---\n_Session: {sid} · Tools used: {len(trace)}_\n"
        )
        out["gcs_path"] = memory.append_digest(date_str, digest_md)
    return out


# ---- LangGraph Activities (Ollama orchestration) ----

@app.post("/activity")
def run_activity(body: ActivityIn):
    """Execute a single LangGraph activity."""
    if not body.activity_type:
        raise HTTPException(400, "activity_type required")

    result = _activities.run_activity(
        activity_type=body.activity_type,
        prompt=body.prompt,
        project_path=body.project_path or f"/tmp/beastbrain_{datetime.now().timestamp()}",
        context=body.context or {}
    )

    # Add to session for continuity
    session_id = body.context.get("session_id") if body.context else None
    if session_id:
        activity_log = session_manager.add_activity_to_session(session_id, body.activity_type, result)
        result["activity_logged"] = True
        result["log_entry"] = activity_log

    return result


@app.post("/workflow")
def run_workflow(body: WorkflowIn):
    """Execute a full workflow: Ollama plans, activities execute."""
    if not body.prompt.strip():
        raise HTTPException(400, "prompt required")

    try:
        result = ollama_agent.execute_workflow(body.prompt)
        return result
    except Exception as e:
        raise HTTPException(502, f"workflow failed: {type(e).__name__}: {e}")


@app.get("/activities")
def list_activities():
    """List available activities."""
    return {
        "activities": list(_activities.ACTIVITIES.keys()),
        "descriptions": {
            "build_site": "Create an HTML/CSS/JS website from scratch",
            "create_bot": "Generate a Discord/Telegram/Slack bot",
            "edit_code": "Analyze, refactor, and test code",
            "deploy": "Prepare and deploy to Cloud Run"
        }
    }


@app.post("/api/ollama/tools/call")
def api_ollama_tools_call(body: PluginCallIn):
    """Dispatch an Ollama-specific tool (code gen, debugging, etc)."""
    return ollama_agent.call_ollama_tool(body.name, body.args or {})


@app.get("/api/ollama/tools")
def api_ollama_tools():
    """List available Ollama tools."""
    return {
        "tools": [
            {
                "name": s["name"],
                "description": s["description"],
                "params": s["params"],
            }
            for s in ollama_agent.OLLAMA_SPECS
        ]
    }


# ---- Session Continuity & Instance Switching ----

@app.get("/instance/info")
def instance_info():
    """Get current instance info."""
    return session_manager.get_instance_info()


@app.get("/sessions/continuity/{session_id}")
def session_continuity(session_id: str):
    """Get session info with continuity metadata."""
    return session_manager.enrich_session(session_id)


class SwitchInstanceIn(BaseModel):
    session_id: str
    target: str = "cloud"


@app.post("/sessions/switch")
def switch_instance(body: SwitchInstanceIn):
    """Switch instances while maintaining session continuity."""
    if body.target not in ("local", "cloud"):
        raise HTTPException(400, "target must be 'local' or 'cloud'")
    return session_manager.switch_instance(body.session_id, body.target)


@app.get("/sessions/all-instances")
def list_all_sessions():
    """List all sessions with instance continuity info."""
    return {
        "sessions": session_manager.list_sessions_with_instances(limit=50),
        "continuity_stats": session_manager.get_continuity_stats(),
    }


@app.get("/sessions/continuity/stats")
def continuity_stats():
    """Get continuity statistics."""
    return {
        "current_instance": session_manager.get_instance_info()["instance"],
        "stats": session_manager.get_continuity_stats(),
    }


# ---- Integration Framework (Pluggable Tools) ----

class IntegrationCallIn(BaseModel):
    integration: str  # Name of integration to call
    task: str  # Task to execute
    params: dict = {}  # Parameters for task


class SituationCallIn(BaseModel):
    action: str  # Action (create, list, validate, search, etc.)
    target: str  # Target (issue, pr, email, web, etc.)
    params: dict = {}  # Parameters for task
    integration: str | None = None  # Optional explicit integration


@app.post("/integrations/call")
async def integrations_call(body: IntegrationCallIn):
    """Call a specific integration directly."""
    try:
        result = await _integration_registry.execute(body.integration, body.task, body.params)
        return result
    except Exception as e:
        return {"status": "error", "error": f"{type(e).__name__}: {e}"}


@app.post("/integrations/route")
async def integrations_route(body: SituationCallIn):
    """Route to integration based on context (action + target)."""
    try:
        context = {
            "action": body.action,
            "target": body.target,
            "params": body.params,
        }
        if body.integration:
            context["integration"] = body.integration
        result = await _situation_router.route(context)
        return result
    except Exception as e:
        return {"status": "error", "error": f"{type(e).__name__}: {e}"}


@app.get("/integrations/list")
async def integrations_list():
    """List available integrations."""
    config = _integration_registry.config
    available = [
        {
            "name": name,
            "enabled": config.get("enabled", True),
            "description": config.get("description", ""),
        }
        for name, config in config.get("integrations", {}).items()
    ]
    return {
        "integrations": available,
        "fallback": config.get("fallback_integration", "custom_tool"),
        "routing_rules": list(_situation_router.rules.keys()),
    }


@app.get("/integrations/{name}/health")
async def integrations_health(name: str):
    """Check health of a specific integration."""
    try:
        integration = await _integration_registry.load_integration(name)
        is_healthy = await integration.health_check()
        return {
            "integration": name,
            "is_healthy": is_healthy,
            "is_ready": integration.is_ready,
            "last_error": integration.last_error,
        }
    except Exception as e:
        return {
            "integration": name,
            "is_healthy": False,
            "error": str(e),
        }


# ---- Computer Environment (Autonomous Sandbox) ----

class ComputerActionIn(BaseModel):
    session_id: str
    action: str  # screenshot, file_create, file_read, command_execute, etc.
    params: dict = {}


@app.post("/computer/action")
async def computer_action(body: ComputerActionIn):
    """Execute action in computer environment (Manus-like sandbox)."""
    try:
        # Use computer integration
        params = {"session_id": body.session_id, **body.params}
        result = await _integration_registry.execute("computer", body.action, params)
        return result
    except Exception as e:
        return {"status": "error", "error": f"{type(e).__name__}: {e}"}


