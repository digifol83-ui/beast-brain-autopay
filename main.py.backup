def _document_token(request: Request) -> str | None:
    return (
        request.headers.get("x-beastbrain-documents-token")
        or request.query_params.get("token")
        or request.cookies.get("beastbrain_documents_token")
    )


@app.get("/api/documents")
async def documents_api(request: Request):
    return document_vault.list_documents(_document_token(request))


@app.get("/api/documents/intelligence")
async def documents_intelligence_api(request: Request):
    return document_intelligence.analyze_vault(_document_token(request))


@app.post("/api/documents/{document_id}/prepare")
async def document_prepare(document_id: str, body: DocumentPrepareIn, request: Request):
    return document_preparation.prepare_document(
        document_id,
        _document_token(request),
        message=body.message,
        operator_note=body.operator_note,
    )


@app.get("/api/documents/{document_id}/download")
async def document_download(document_id: str, request: Request):
    data, filename = document_vault.download_document(document_id, _document_token(request))
    safe_filename = filename.replace('"', "").replace("\\", "")
    return Response(
        content=data,
        media_type="application/pdf",
        headers={
            "Content-Disposition": f'attachment; filename="{safe_filename}"',
            "Cache-Control": "private, no-store",
        },
    )


