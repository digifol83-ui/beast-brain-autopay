@app.get("/api/crypto/price")
def crypto_price(ids: str = "bitcoin,ethereum,solana,matic-network"):
    """Get live crypto prices from CoinGecko."""
    import requests
    key = os.getenv("COINGECKO_API_KEY")
    if not key:
        raise HTTPException(500, "COINGECKO_API_KEY not configured")
    
    resp = requests.get(
        "https://api.coingecko.com/api/v3/simple/price",
        params={"ids": ids, "vs_currencies": "usd"},
        headers={"x-cg-demo-api-key": key},
        timeout=10
    )
    if resp.status_code != 200:
        raise HTTPException(resp.status_code, f"CoinGecko error: {resp.text}")
    return {"status": "live", "prices": resp.json(), "source": "coingecko_pro"}


@app.get("/api/wallet/balance")
def wallet_balance(address: str, chain: str = "polygon"):
    """Get wallet balance from Moralis."""
    import requests
    key = os.getenv("MORALIS_API_KEY")
    if not key:
        raise HTTPException(500, "MORALIS_API_KEY not configured")
    
    # Get native balance
    bal_resp = requests.get(
        f"https://deep-index.moralis.io/api/v2/{address}?chain={chain}",
        headers={"X-API-Key": key},
        timeout=10
    )
    balance = {}
    if bal_resp.status_code == 200:
        data = bal_resp.json()
        balance = {
            "native_balance_wei": data.get("balance", "0"),
            "native_balance": str(int(data.get("balance", "0")) / 1e18),
            "nonce": data.get("nonce", 0)
        }
    
    # Get ERC20 tokens
    tok_resp = requests.get(
        f"https://deep-index.moralis.io/api/v2/{address}/erc20?chain={chain}",
        headers={"X-API-Key": key},
        timeout=10
    )
    tokens = []
    if tok_resp.status_code == 200:
        for t in tok_resp.json():
            tokens.append({
                "symbol": t.get("symbol"),
                "balance": str(int(t.get("balance", 0)) / (10 ** int(t.get("decimals", 18)))),
                "address": t.get("token_address")
            })
    
    return {"status": "live", "address": address, "chain": chain, "balance": balance, "tokens": tokens, "source": "moralis"}


@app.get("/api/wallet/tx-history")
def wallet_tx_history(address: str, chain: str = "polygon", limit: int = 10):
    """Get transaction history from Moralis."""
    import requests
    key = os.getenv("MORALIS_API_KEY")
    if not key:
        raise HTTPException(500, "MORALIS_API_KEY not configured")
    
    resp = requests.get(
        f"https://deep-index.moralis.io/api/v2/{address}?chain={chain}&limit={limit}",
        headers={"X-API-Key": key},
        timeout=10
    )
    if resp.status_code != 200:
        raise HTTPException(resp.status_code, f"Moralis error: {resp.text}")
    
    data = resp.json()
    return {
        "status": "live",
        "address": address,
        "chain": chain,
        "transactions": data.get("result", []),
        "source": "moralis"
    }


@app.get("/api/blockchain/eth-block")
def eth_block_number():
    """Get latest Ethereum block number from Infura."""
    import requests
    key = os.getenv("INFURA_API_KEY")
    if not key:
        raise HTTPException(500, "INFURA_API_KEY not configured")
    
    resp = requests.post(
        f"https://mainnet.infura.io/v3/{key}",
        json={"jsonrpc": "2.0", "method": "eth_blockNumber", "params": [], "id": 1},
        timeout=10
    )
    if resp.status_code != 200:
        raise HTTPException(resp.status_code, f"Infura error: {resp.text}")
    
    data = resp.json()
    block_hex = data.get("result", "0x0")
    return {
        "status": "live",
        "block_number": int(block_hex, 16),
        "block_hex": block_hex,
        "source": "infura"
    }


@app.get("/api/blockchain/eth-gas")
def eth_gas_price():
    """Get Ethereum gas price from Infura."""
    import requests
    key = os.getenv("INFURA_API_KEY")
    if not key:
        raise HTTPException(500, "INFURA_API_KEY not configured")
    
    resp = requests.post(
        f"https://mainnet.infura.io/v3/{key}",
        json={"jsonrpc": "2.0", "method": "eth_gasPrice", "params": [], "id": 1},
        timeout=10
    )
    if resp.status_code != 200:
        raise HTTPException(resp.status_code, f"Infura error: {resp.text}")
    
    data = resp.json()
    gas_hex = data.get("result", "0x0")
    gas_wei = int(gas_hex, 16)
    return {
        "status": "live",
        "gas_price_wei": gas_wei,
        "gas_price_gwei": gas_wei / 1e9,
        "source": "infura"
    }


