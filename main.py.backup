@app.get("/wert-widget", response_class=HTMLResponse)
def wert_widget(partner_id: str, session_id: str, origin: str = "https://widget.wert.io", click_id: str | None = None):
    """Load Wert's official widget SDK from a backend-created session."""
    if not partner_id or not session_id:
        raise HTTPException(400, "partner_id and session_id are required")
    options = {
        "partner_id": partner_id,
        "session_id": session_id,
        "origin": origin,
    }
    if click_id:
        options["click_id"] = click_id
    options_json = json.dumps(options)
    return HTMLResponse(f"""<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Wert Checkout</title>
  <style>
    body {{ margin: 0; font-family: system-ui, -apple-system, Segoe UI, sans-serif; background: #0b1020; color: #f8fafc; }}
    .status {{ min-height: 100vh; display: grid; place-items: center; padding: 24px; text-align: center; }}
    .status strong {{ display: block; margin-bottom: 8px; }}
  </style>
</head>
<body>
  <div class="status">
    <div>
      <strong>Loading Wert checkout...</strong>
      <span>Card details and verification stay inside Wert.</span>
    </div>
  </div>
  <script type="module">
    import WertWidget from 'https://esm.sh/@wert-io/widget-initializer?bundle';
    const widget = new WertWidget({options_json});
    widget.open();
  </script>
</body>
</html>""")


