@app.post("/api/banxa/checkout")
def banxa_checkout(payload: dict):
    """Create a Banxa buy order with BeastBrain Solana wallet as destination.
    
    Args:
        payload: {
            "amount": float (fiat amount),
            "currency": str (e.g. "AED", "USD"),
            "crypto": str (e.g. "USDT", "BTC"),
            "email": str (customer email),
            "reference": str (optional order reference)
        }
    
    Returns:
        {"checkout_url": str, "order_id": str, "status": str}
    """
    import httpx
    import uuid
    from datetime import datetime
    
    amount = payload.get("amount", 100.0)
    currency = (payload.get("currency") or "AED").upper()
    crypto = (payload.get("crypto") or "USDT").upper()
    email = payload.get("email", "sichermayorfx@gmail.com")
    reference = payload.get("reference") or f"bb-{uuid.uuid4().hex[:12]}"
    
    # BeastBrain permanent Solana wallet
    wallet_address = "7T34pXqwy666yjZXuFWNQo6tFVHukNgPdx9VCcf7W8J7"
    
    # Call BeastPay API to create Banxa order
    beastpay_url = "https://beastpay-api-544494288390.us-central1.run.app"
    
    order_payload = {
        "amount": amount,
        "fiat_currency": currency,
        "crypto_currency": crypto,
        "wallet_address": wallet_address,
        "customer_email": email,
        "reference": reference,
        "success_url": f"https://beastbrain.sichermayor.online/card-to-crypto?order={reference}",
        "cancel_url": f"https://beastbrain.sichermayor.online/card-to-crypto?cancelled={reference}",
        "description": f"BeastBrain Banxa Checkout - {amount} {currency} to {crypto}",
    }
    
    try:
        with httpx.Client(timeout=20) as client:
            resp = client.post(
                f"{beastpay_url}/api/payments",
                json=order_payload,
                headers={"X-API-Key": "85b62872d9840950e8d8d2a9f991c4b6c02b748562fc6bdbd4490eac74e535eb"}
            )
            resp.raise_for_status()
            data = resp.json()
            
            return {
                "status": "created",
                "order_id": data.get("result", {}).get("payment_id"),
                "checkout_url": data.get("result", {}).get("checkout_url"),
                "provider": "banxa",
                "wallet_address": wallet_address,
                "amount": amount,
                "currency": currency,
                "crypto": crypto,
                "reference": reference,
            }
    except httpx.HTTPError as e:
        raise HTTPException(status_code=502, detail=f"BeastPay API error: {str(e)}")
    gateway_params = urllib.parse.urlencode({"gateway_id": "onramper", "email": "sichermayorfx@gmail.com", "wallet_address": "7T34pXqwy666yjZXuFWNQo6tFVHukNgPdx9VCcf7W8J7"})

    routes = [
        {"id": "onramper", "route_type": "hosted_card_to_crypto", "login_reuse_mode": "provider_account_or_browser_session", "beastbrain_checkout_url": f"/api/card-to-crypto/checkout?{gateway_params}"},
        {"id": "ramp_network", "route_type": "hosted_card_to_crypto", "login_reuse_mode": "provider_account_or_browser_session", "beastbrain_checkout_url": "/api/card-to-crypto/checkout?gateway_id=ramp_network"},
        {"id": "moonpay", "route_type": "hosted_card_to_crypto", "login_reuse_mode": "provider_account_or_browser_session", "beastbrain_checkout_url": "/api/card-to-crypto/checkout?gateway_id=moonpay"},
        {"id": "banxa", "route_type": "hosted_card_to_crypto", "login_reuse_mode": "provider_account_or_browser_session", "beastbrain_checkout_url": "/api/card-to-crypto/checkout?gateway_id=banxa"},
        {"id": "onramper_tron_usdt_fallback", "route_type": "hosted_card_to_crypto_quote_fallback", "status_color": "yellow", "quote_fallback_for": "AED+USDT+solana+moonpay_no_quote", "provider_crypto": "USDT", "provider_crypto_id": "USDT", "target_crypto": "USDT", "two_step_conversion_required": False, "network": "tron", "network_label": "TRON / TRC20", "withdrawal_asset_label": "USDT (TRC20)", "wallet_address": "TGUZPsLn7g2NFee8N5W76FjtewCE8QFzFE", "browser_checkout_url": "/card-to-crypto/browser/checkout?crypto=USDT&network=tron&wallet_address=TGUZPsLn7g2NFee8N5W76FjtewCE8QFzFE", "beastbrain_checkout_url": "/api/card-to-crypto/checkout?crypto_currency=USDT&network=tron&wallet_address=TGUZPsLn7g2NFee8N5W76FjtewCE8QFzFE"},
        {"id": "bybit_p2p", "route_type": "manual_p2p_to_wallet", "completion_rule": "Complete only after exchange release, withdrawal, and wallet tx hash proof."},
    ]
    return {
        "status": "activated_gateway_router_ready",
        "customer_email": "sichermayorfx@gmail.com",
        "auto_route_strategy": "green_hosted_first_then_p2p_backup",
        "login_session_owner": "hosted_provider_or_customer_browser",
        "beastbrain_password_storage": False, "beastbrain_session_storage": False,
        "raw_card_data_stored": False, "merchant_otp_supported": False, "merchant_side_3ds_supported": False,
        "direct_card_entry": False,
        "update_sources": ["provider_webhook_or_order_status", "provider_account_dashboard_confirmation", "operator_verified_metadata", "wallet_transaction_hash_proof"],
        "preferred_token_network": {"token": "USDT", "network": "solana", "network_label": "Solana / SPL", "withdrawal_asset_label": "USDT (SPL)", "wallet_address": "7T34pXqwy666yjZXuFWNQo6tFVHukNgPdx9VCcf7W8J7"},
        "routes": routes,
    }


