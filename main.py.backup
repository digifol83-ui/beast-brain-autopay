MAX_ATTACHMENT_BYTES = 10 * 1024 * 1024  # 10 MB per file
MAX_ATTACHMENTS_PER_TURN = 4


@app.post("/chat")
def chat(
    body: ChatIn,
    openai_api_key: str | None = Header(default=None, alias="X-OpenAI-API-Key"),
    x_api_key: str | None = Header(default=None, alias="X-API-Key"),
):
    if not body.message.strip() and not body.attachments:
        raise HTTPException(400, "message or attachments required")

    # Validate attachments
    if len(body.attachments) > MAX_ATTACHMENTS_PER_TURN:
        raise HTTPException(400, f"max {MAX_ATTACHMENTS_PER_TURN} attachments per turn")
    import base64
    norm_atts = []
    for att in body.attachments:
        try:
            raw = base64.b64decode(att.data_b64, validate=False)
        except Exception:
            raise HTTPException(400, f"attachment '{att.name}' is not valid base64")
        if len(raw) > MAX_ATTACHMENT_BYTES:
            raise HTTPException(400, f"attachment '{att.name}' exceeds {MAX_ATTACHMENT_BYTES} bytes")
        norm_atts.append({"name": att.name, "mime": att.mime, "data_b64": att.data_b64, "size": len(raw)})

    sid = body.session_id or memory.new_session_id()
    session = memory.load(sid)
    user_msg: dict = {"role": "user", "content": body.message}
    if norm_atts:
        user_msg["attachments"] = norm_atts
    session["messages"].append(user_msg)

    try:
        reply, trace, reasoner_used = llm.run(
            session["messages"],
            reasoner=body.reasoner,
            enabled_tools=body.enabled_tools,
            openai_api_key=openai_api_key,
        )
    except Exception as e:
        raise HTTPException(502, f"agent failure: {type(e).__name__}: {e}")

    session["messages"].append({"role": "assistant", "content": reply, "trace": trace, "reasoner": reasoner_used})
    memory.save(session)

    return {
        "session_id": sid,
        "reply": reply,
        "reasoner": reasoner_used,
        "trace": trace,
        "attachments_received": len(norm_atts),
    }


class SaveMessageIn(BaseModel):
    session_id: str | None = None
    role: str  # "user" or "assistant"
    content: str
    reasoner: str | None = None
    trace: list | None = None


@app.post("/chat/save-message")
def save_message(body: SaveMessageIn):
    """Save a message to the session. Used by Ollama (browser-side) to persist to server."""
    if not body.role in ("user", "assistant"):
        raise HTTPException(400, "role must be 'user' or 'assistant'")

    sid = body.session_id or memory.new_session_id()
    session = memory.load(sid)

    msg: dict = {"role": body.role, "content": body.content}
    if body.reasoner:
        msg["reasoner"] = body.reasoner
    if body.trace is not None:
        msg["trace"] = body.trace

    session["messages"].append(msg)
    memory.save(session)

    return {"session_id": sid}


