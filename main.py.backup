    return HTMLResponse(content=html)


class VisaPaymentIntentIn(BaseModel):
    amount_usd: float
    currency: str = "usd"
    description: str = ""
    metadata: dict[str, str] = {}


@app.post("/api/visa/create-payment-intent")
def visa_create_payment_intent(body: VisaPaymentIntentIn):
    """Create a Stripe PaymentIntent for visa application payments."""
    if body.amount_usd <= 0:
        raise HTTPException(400, "amount_usd must be positive")
    try:
        amount_cents = int(body.amount_usd * 100)
        form: list[tuple[str, str]] = [
            ("amount", str(amount_cents)),
            ("currency", body.currency.lower()),
            ("description", body.description or "Visa application payment"),
            ("payment_method_types[]", "card"),
        ]
        for key, value in body.metadata.items():
            form.append((f"metadata[{key}]", str(value)))
        intent = stripe_gateway.stripe_post("/payment_intents", form)
        return {"client_secret": intent.get("client_secret"), "payment_intent_id": intent.get("id")}
    except stripe_gateway.StripeConfigError as exc:
        raise HTTPException(503, str(exc))
    except stripe_gateway.StripeAPIError as exc:
        raise HTTPException(exc.status_code if exc.status_code < 600 else 502, str(exc))


AUTOPAY_DIRECT_UI_PATH = Path(__file__).parent / "autopay_direct_ui.html"


AUTOPAY_START_UI_PATH = Path(__file__).parent / "web" / "autopay_start.html"


@app.get("/autopay/start", response_class=HTMLResponse)
@app.get("/autopay", response_class=HTMLResponse)
async def autopay_start_ui():
    """Single URL to start auto-pay ABCD flow."""
    if not AUTOPAY_START_UI_PATH.exists():
        return HTMLResponse("<h1>Auto-Pay Start</h1><p>UI not found.</p>")
    html = AUTOPAY_START_UI_PATH.read_text(encoding="utf-8")
    pub_key = os.getenv("STRIPE_PUBLISHABLE_KEY", "")
    html = html.replace("{{PUBLISHABLE_KEY}}", pub_key)
    html = html.replace("{{EMAIL}}", "")
    return HTMLResponse(content=html)


